{# ---- HERO CAROUSEL (TEXT INSIDE IMAGE, IMAGE ORIGINAL SIZE) ---- #}

<style>
  /* Container */
  .hero-carousel{
    --pad: clamp(14px, 2.2vw, 26px);
  }

  .hero-carousel .carousel-inner{
    border: 1px solid rgba(15,23,42,.10);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 14px 40px rgba(2,6,23,.08);
  }

  /* Slide layout: center image with its natural size */
  .hero-slide{
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--pad);
  }

  /* Image: original size, responsive */
  .hero-img{
    width: 100%;
    height: auto;
    max-width: 100%;
    max-height: 520px;
    display: block;
  }

  /* Soft overlay gradient for text readability (on top of the image only) */
  .hero-slide::after{
    content:"";
    position:absolute;
    inset: var(--pad);
    border-radius: 14px;
    pointer-events:none;
  }

  /* Text overlay inside the image */
  .hero-overlay{
    position:absolute;
    inset: var(--pad);
    border-radius: 14px;
    display:flex;
    align-items:flex-end;
    padding: clamp(12px, 2vw, 22px);
    z-index: 2;
    pointer-events:none;
  }

  .hero-card {
    pointer-events: auto;
    max-width: 760px;
    color: #fff;
    background: rgb(2 6 23 / 18%);
    border: 1px solid rgba(255, 255, 255, .18);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 18px;
    padding: 16px 18px;
    box-shadow: 0 18px 55px rgba(0, 0, 0, .20);
  }

  .hero-kicker{
    display:inline-flex;
    align-items:center;
    gap:.55rem;
    font-weight: 800;
    letter-spacing: .10em;
    font-size: .78rem;
    text-transform: uppercase;
    color: rgba(255,255,255,.92);
    padding: .35rem .7rem;
    border-radius: 999px;
    margin-bottom: .6rem;
  }

  .hero-title{
    font-weight: 900;
    font-size: clamp(1.25rem, 2.4vw, 2.15rem);
    line-height: 1.08;
    margin: 0;
    text-shadow: 0 10px 30px rgba(0,0,0,.25);
  }

  .hero-text{
    margin: .55rem 0 1rem;
    color: rgba(255,255,255,.88);
    font-size: 1.02rem;
    max-width: 58ch;
  }

  /* Buttons modern */
  .hero-card .btn{
    border-radius: 999px;
    padding-inline: 1.15rem;
    font-weight: 700;
  }
  .btn-glass{
    color:#fff;
    background: rgba(255,255,255,.10);
    border: 1px solid rgba(255,255,255,.22);
  }
  .btn-glass:hover{
    color:#fff;
    background: rgba(255,255,255,.16);
  }

  /* Indicators */
  .hero-carousel .carousel-indicators [data-bs-target]{
    width: 10px;
    height: 10px;
    border-radius: 999px;
  }

  /* Mobile: overlay a little higher */
  @media (max-width: 576px){
    .hero-img{ max-height: 420px; }
    .hero-text{ font-size: .95rem; }
    .hero-card{ padding: 14px 14px; }
  }

  /* Admin actions */
  .hero-admin-actions{
    position:absolute;
    top: calc(var(--pad) + 10px);
    right: calc(var(--pad) + 10px);
    z-index: 3;
    display:flex;
    gap:.5rem;
    pointer-events:auto;
  }
  .hero-admin-actions .btn{
    border-radius: 999px;
    padding: .45rem .6rem;
    line-height: 1;
  }
</style>

<section class="container my-3">
  {% if slides is defined and slides|length > 0 %}
    <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="6500">

      {# Indicators dynamiques #}
      <div class="carousel-indicators">
        {% for s in slides %}
          <button type="button"
                  data-bs-target="#heroCarousel"
                  data-bs-slide-to="{{ loop.index0 }}"
                  class="{{ loop.first ? 'active' : '' }}"
                  {{ loop.first ? 'aria-current="true"' : '' }}
                  aria-label="Slide {{ loop.index }}"></button>
        {% endfor %}
      </div>

      <div class="carousel-inner">

        {% for s in slides %}
          <div class="carousel-item {{ loop.first ? 'active' : '' }}">
            <div class="hero-slide">

              {# =========================
                 IMAGE
                 Option A: si tu stockes un chemin complet relatif dans imagePath:
                 ========================= #}
              {# <img src="{{ asset(s.imagePath) }}" class="hero-img" alt="{{ s.altText|default('Slide') }}"> #}

              {# =========================
                 Option B: si tu stockes juste le nom de fichier dans imageName (ex: slide1.jpg):
                 et tu les mets dans public/img/slides/
                 ========================= #}
              <img src="{{ asset('img/slides/' ~ s.image) }}"
                   class="hero-img"
                   alt="{{ s.altText|default(s.title|default('Slide')) }}"
                   loading="lazy">

              {# ✅ Actions admin (edit / delete / mise en avant) #}
              {% if is_granted('ROLE_ADMIN') %}
                <div class="hero-admin-actions">

                  {# ✅ Mise en avant => bump #}
                  <form method="post" action="{{ path('admin_hero_slide_bump', {id: s.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('bump_slide_' ~ s.id) }}">
                    <button class="btn btn-warning btn-sm" type="submit" title="Mettre en avant">
                      <i class="fa-solid fa-thumbtack"></i>
                    </button>
                  </form>

                  <a class="btn btn-light btn-sm"
                     href="{{ path('admin_hero_slide_edit', {id: s.id}) }}"
                     title="Modifier">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </a>

                  {# ✅ Delete #}
                  <form method="post"
                        action="{{ path('admin_hero_slide_delete', {id: s.id}) }}"
                        class="d-inline"
                        onsubmit="return confirm('Supprimer ce slide ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_slide_' ~ s.id) }}">
                    <button class="btn btn-danger btn-sm" type="submit" title="Supprimer">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>

                </div>
              {% endif %}

              {# Overlay texte + boutons (tu peux remplir via champs DB) #}
              <div class="hero-overlay">
                <div class="hero-card">

                  {# Si tu veux: kicker/titre/texte venant de la DB #}
                  {% if s.kicker is defined and s.kicker %}
                    <div class="hero-kicker">
                      <i class="fa-solid fa-bolt"></i> {{ s.kicker }}
                    </div>
                  {% endif %}

                  {% if s.title is defined and s.title %}
                    <h2 class="hero-title">{{ s.title }}</h2>
                  {% endif %}

                  {% if s.subtitle is defined and s.subtitle %}
                    <p class="hero-text">{{ s.subtitle }}</p>
                  {% endif %}

                  {# =========================
                     Boutons du slide (fallback si vide)
                     Champs attendus: primaryLabel, primaryUrl, secondaryLabel, secondaryUrl
                     ========================= #}

                  {% set pLabel = (s.primaryLabel is defined and s.primaryLabel|trim != '') ? s.primaryLabel : 'Voir le catalogue' %}
                  {% set pUrl   = (s.primaryUrl   is defined and s.primaryUrl|trim   != '') ? s.primaryUrl   : path('articles_page') %}

                  {% set sLabel = (s.secondaryLabel is defined and s.secondaryLabel|trim != '') ? s.secondaryLabel : 'Nouveautés' %}
                  {% set sUrl   = (s.secondaryUrl   is defined and s.secondaryUrl|trim   != '') ? s.secondaryUrl   : path('articles_page') %}

                  <div class="d-flex gap-2 flex-wrap">
                    <a href="{{ pUrl }}" class="btn btn-primary">
                      <i class="fa-solid fa-border-all me-2"></i>{{ pLabel }}
                    </a>

                    <a href="{{ sUrl }}" class="btn btn-glass">
                      <i class="fa-solid fa-star me-2"></i>{{ sLabel }}
                    </a>
                  </div>

                </div>
              </div>

            </div>
          </div>
        {% endfor %}

      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
      </button>
    </div>

    {# Bouton ajouter (uniquement admin) #}
    {% if is_granted('ROLE_ADMIN') %}
      <div class="d-flex justify-content-end mt-2">
        <a href="{{ path('admin_hero_slide_new') }}" class="btn btn-outline-primary rounded-pill px-3">
          <i class="fa-solid fa-circle-plus me-2"></i>Ajouter un slide
        </a>
      </div>
    {% endif %}

  {% else %}
    {# Aucun slide #}
    <div class="alert alert-light border">
      <div class="fw-bold">Aucun slide</div>
      {% if is_granted('ROLE_ADMIN') %}
        <div class="mt-2">
          <a href="{{ path('admin_hero_slide_new') }}" class="btn btn-primary rounded-pill">
            <i class="fa-solid fa-circle-plus me-2"></i>Ajouter le premier slide
          </a>
        </div>
      {% endif %}
    </div>
  {% endif %}
</section>