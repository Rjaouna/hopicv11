{# templates/home/sections/_new_articles.html.twig #}

<style>
  :root{
    --pc-radius: 18px;
    --pc-border: rgba(0,0,0,.10);
    --pc-shadow: 0 14px 34px rgba(0,0,0,.08);
    --pc-muted: rgba(0,0,0,.58);
  }
  body.theme-dark{
    --pc-border: rgba(255,255,255,.14);
    --pc-shadow: 0 18px 46px rgba(0,0,0,.35);
    --pc-muted: rgba(255,255,255,.65);
  }

  /* ✅ même grille + mêmes cartes que /articles */
  [data-new-section] .product-grid{
    display:grid;
    grid-template-columns: repeat(2, minmax(0,1fr));
    gap: 14px;
  }
  @media (min-width: 768px){
    [data-new-section] .product-grid{ grid-template-columns: repeat(3, minmax(0,1fr)); }
  }
  @media (min-width: 1200px){
    [data-new-section] .product-grid{ grid-template-columns: repeat(4, minmax(0,1fr)); }
  }

  [data-new-section] .product-card{
    position: relative;
    border-radius: var(--pc-radius);
    border: 1px solid var(--pc-border);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    background: rgba(255,255,255,.85);
    overflow: hidden;
    transition: transform .08s ease, box-shadow .12s ease, border-color .12s ease;
  }
  body.theme-dark [data-new-section] .product-card{ background: rgba(18,18,22,.70); }

  [data-new-section] .product-card:hover{
    transform: translateY(-2px);
    box-shadow: 0 16px 32px rgba(0,0,0,.10);
    border-color: rgba(13,110,253,.22);
  }

  /* ✅ stock (à la place du coeur wishlist) */
  [data-new-section] .wishlist-button{
    position:absolute;
    top:10px; right:10px;
    width: 40px; height: 40px;
    border-radius: 14px;
    border: 1px solid var(--pc-border);
    background: rgba(255,255,255,.82);
    display:grid; place-items:center;
    z-index: 5;
  }
  body.theme-dark [data-new-section] .wishlist-button{ background: rgba(18,18,22,.72); }

  [data-new-section] .product-card__image{
    position: relative;
    padding: 14px;
    background: linear-gradient(180deg, rgba(0,0,0,.02), transparent);
  }

  /* ✅ quantité panier haut-gauche */
  [data-new-section] .badge-pill{
    position:absolute;
    left: 12px;
    top: 12px;
    display:flex; align-items:center; gap:6px;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.80);
    font-weight: 900;
    font-size: .78rem;
    z-index: 4;
  }
  body.theme-dark [data-new-section] .badge-pill{
    border-color: rgba(255,255,255,.14);
    background: rgba(18,18,22,.70);
  }

  /* ✅ badge image nouveauté centré */
  [data-new-section] .badge-newimg{
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    pointer-events: none;
    display:flex;
    justify-content:center;
    align-items:center;
  }
  [data-new-section] .badge-newimg img{
    width: min(220px, 100%);
    height: auto;
    filter: drop-shadow(0 10px 18px rgba(0,0,0,.18));
  }
  body.theme-dark [data-new-section] .badge-newimg img{
    filter: drop-shadow(0 14px 24px rgba(0,0,0,.55));
  }

  [data-new-section] .product-img{
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: contain;
    border-radius: 16px;
    background: rgba(255,255,255,.35);
    padding: 12px;
    border: 1px solid rgba(0,0,0,.06);
  }
  body.theme-dark [data-new-section] .product-img{
    background: rgba(255,255,255,.03);
    border-color: rgba(255,255,255,.10);
  }

  [data-new-section] .product-card__info{ padding: 12px 14px 0 14px; }

  [data-new-section] .refPlusCopy{
    display:flex; align-items:center; gap:8px;
    font-weight: 900;
    font-size: .95rem;
  }
  [data-new-section] .product-reference{ text-decoration:none; color: inherit; }

  [data-new-section] .designation{
    display:block;
    margin-top: 6px;
    font-weight: 800;
    font-size: .92rem;
    color: rgba(0,0,0,.75);
    text-decoration:none;
  }
  body.theme-dark [data-new-section] .designation{ color: rgba(255,255,255,.86); }

  [data-new-section] .meta-line{
    margin-top: 8px;
    font-size: .80rem;
    color: var(--pc-muted);
    display:flex;
    flex-wrap:wrap;
    gap: 8px;
  }
  [data-new-section] .meta-chip{
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.7);
    border-radius: 999px;
    padding: 4px 8px;
    font-weight: 800;
  }
  body.theme-dark [data-new-section] .meta-chip{
    border-color: rgba(255,255,255,.14);
    background: rgba(18,18,22,.62);
  }

  [data-new-section] .product-card__footer{ padding: 12px 14px 14px 14px; }

  [data-new-section] .product-card__prices{
    display:flex;
    align-items:baseline;
    gap: 8px;
    font-weight: 950;
  }
  [data-new-section] .price-ttc{ font-size: 1.05rem; }
  [data-new-section] .price-label{ font-size: .78rem; color: var(--pc-muted); font-weight: 900; }

  [data-new-section] .bottomFooterWrapper{
    margin-top: 10px;
    display:flex;
    align-items:center;
    gap: 10px;
  }

  /* ✅ Stepper quantité (comme ta photo) */
  [data-new-section] .qty-stepper{
    display:flex;
    align-items:stretch;
    height: 44px;
    border: 1px solid var(--pc-border);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255,255,255,.92);
    width: 160px;
    flex: 0 0 auto;
  }
  body.theme-dark [data-new-section] .qty-stepper{ background: rgba(18,18,22,.70); }

  [data-new-section] .qty-btn{
    width: 44px;
    border: 0;
    background: transparent;
    display:grid;
    place-items:center;
    font-weight: 900;
    color: rgba(0,0,0,.65);
    transition: background .12s ease, color .12s ease;
    flex: 0 0 44px;
  }
  body.theme-dark [data-new-section] .qty-btn{ color: rgba(255,255,255,.75); }

  [data-new-section] .qty-btn:hover{ background: rgba(0,0,0,.05); }
  body.theme-dark [data-new-section] .qty-btn:hover{ background: rgba(255,255,255,.06); }

  [data-new-section] .qty-btn:disabled{
    opacity: .45;
    cursor: not-allowed;
  }

  [data-new-section] .qty-field{
    flex: 1;
    min-width: 0;
    border: 0;
    outline: none;
    text-align: center;
    font-weight: 950;
    background: transparent;
    color: rgba(0,0,0,.85);
  }
  body.theme-dark [data-new-section] .qty-field{ color: rgba(255,255,255,.90); }
  [data-new-section] .qty-field:disabled{ opacity: .6; }

  [data-new-section] .addcart{
    margin-left:auto;
    width: 44px; height: 44px;
    border-radius: 16px;
    display:grid; place-items:center;
    border: 1px solid rgba(13,110,253,.25);
    background: rgba(13,110,253,.10);
  }
  [data-new-section] .addcart:hover{ background: rgba(13,110,253,.16); }
  [data-new-section] .addcart:disabled{
    opacity: .55;
    cursor: not-allowed;
    background: rgba(0,0,0,.06);
    border-color: rgba(0,0,0,.10);
  }

  /* skeleton identique */
  [data-new-section] .skeleton{
    height: 380px;
    border-radius: var(--pc-radius);
    border: 1px solid rgba(0,0,0,.06);
    background: linear-gradient(90deg, rgba(0,0,0,.04), rgba(0,0,0,.08), rgba(0,0,0,.04));
    background-size: 200% 100%;
    animation: sk 1.2s infinite;
  }
  @keyframes sk { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
</style>

<section class="facet-block mb-3" data-new-section>
  <div class="facet-head">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
      <div class="facet-title">
        <div class="facet-icon" style="background: rgba(25,135,84,.10); border-color: rgba(25,135,84,.20);">⚡</div>
        <div>
          <div class="fw-bold">Nouveautés</div>
          <div class="facet-sub" style="font-size:.92rem; color: var(--pc-muted);">
            10 articles max • filtrés sur les 5 derniers jours
          </div>
        </div>
      </div>

      <a class="btn btn-sm btn-outline-success" href="{{ path('articles_page', { new: 1, newDays: 5 }) }}">
        Voir tout →
      </a>
    </div>
  </div>

  <div class="facet-body">
    <div class="product-grid" data-new-grid>
      {% for i in 1..8 %}
        <div class="skeleton"></div>
      {% endfor %}
    </div>

    <div class="alert alert-danger mt-3 d-none" data-new-error></div>
  </div>
</section>

<script>
(function(){
  const section = document.querySelector('[data-new-section]');
  if (!section) return;

  const grid = section.querySelector('[data-new-grid]');
  const err  = section.querySelector('[data-new-error]');

  const DEFAULT_IMG   = "{{ asset('img/default.png')|e('js') }}";
  const NEW_BADGE_IMG = "{{ asset('img/new.png')|e('js') }}";

  // -------- helpers ----------
  function safeJsonParse(s, fallback){
    try { return JSON.parse(s); } catch(e){ return fallback; }
  }

  function esc(s){
    return String(s ?? '').replace(/[&<>"']/g, m => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[m]));
  }

  function money(v){
    const n = Number(String(v).replace(',', '.'));
    if (!isFinite(n)) return esc(v);
    return n.toFixed(2);
  }

  function truncate(s, max){
    s = String(s ?? '').trim();
    return (s.length <= max) ? s : (s.slice(0, max) + '…');
  }

  // -------- cart (robuste + events) ----------
  function normalizeCartObj(obj){
    if (!obj || typeof obj !== 'object') return {};
    const out = {};
    for (const [k, v] of Object.entries(obj)){
      if (!k) continue;
      if (typeof v === 'number') out[k] = Math.max(0, Math.floor(v));
      else if (v && typeof v === 'object' && v.qty != null) out[k] = { ...v, qty: Math.max(0, Math.floor(Number(v.qty) || 0)) };
      else out[k] = Math.max(0, Math.floor(Number(v) || 0));
    }
    return out;
  }

  function getCart(){
    const raw = safeJsonParse(localStorage.getItem('cart') || '{}', {});
    return normalizeCartObj(raw);
  }

  function setCart(obj, {emit=true} = {}){
    try { localStorage.setItem('cart', JSON.stringify(normalizeCartObj(obj))); } catch(e){}
    if (typeof window.refreshHeaderCounts === 'function'){
      try { window.refreshHeaderCounts(); } catch(e){}
    }
    if (emit) {
      window.dispatchEvent(new CustomEvent('cart:changed'));
    }
  }

  function getCartQtyFromObj(obj, code){
    const v = obj?.[code];
    if (v == null) return 0;
    if (typeof v === 'number') return v;
    if (typeof v === 'object' && v.qty != null) return Number(v.qty) || 0;
    return Number(v) || 0;
  }

  function setCartQtyInObj(obj, code, nextQty){
    const v = obj?.[code];
    if (v && typeof v === 'object') obj[code].qty = nextQty;
    else obj[code] = nextQty;
  }

  // Met à jour les badges quand panier vidé ailleurs
  function refreshBadges(){
    if (!grid) return;
    const cart = getCart();
    grid.querySelectorAll('[data-card-code]').forEach(card => {
      const code = card.getAttribute('data-card-code') || '';
      const badge = card.querySelector('[data-cart-qty]');
      if (badge) badge.textContent = String(getCartQtyFromObj(cart, code));
      if (typeof card._updateUI === 'function'){
        try { card._updateUI(); } catch(e){}
      }
    });
  }

  window.addEventListener('cart:cleared', refreshBadges);
  window.addEventListener('cart:changed', refreshBadges);
  window.addEventListener('storage', (e) => {
    if (!e || !e.key || e.key === 'cart') refreshBadges();
  });

  function stockStyle(stock){
    if (stock === 0) return `border-color: rgba(220,53,69,.30); background: rgba(220,53,69,.16); color: rgba(220,53,69,.98);`;
    if (stock < 5)  return `border-color: rgba(255,193,7,.40); background: rgba(255,193,7,.18); color: rgba(176,117,0,.98);`;
    if (stock > 10) return `border-color: rgba(25,135,84,.30); background: rgba(25,135,84,.16); color: rgba(25,135,84,.98);`;
    return ``;
  }

  function skeletons(){
    if (!grid) return;
    grid.innerHTML = '';
    for (let i=0; i<8; i++){
      const d = document.createElement('div');
      d.className = 'skeleton';
      grid.appendChild(d);
    }
  }

  async function loadNew(){
    if (err) err.classList.add('d-none');
    skeletons();

    try{
      const url = new URL('/api/articles', window.location.origin);
      url.searchParams.set('page', '1');
      url.searchParams.set('limit', '8');
      url.searchParams.set('new', '1');
      url.searchParams.set('newDays', '5');

      const res = await fetch(url.toString(), { headers: { 'Accept':'application/json' } });
      const text = await res.text();
      const data = safeJsonParse(text, {});

      if (!res.ok || !data.ok){
        if (err){
          err.classList.remove('d-none');
          err.innerHTML = `<div class="fw-bold">Erreur API</div>
            <div class="small">Status: ${res.status}</div>
            <div class="small">Début: <code>${esc(text.slice(0, 220))}</code></div>`;
        }
        if (grid) grid.innerHTML = '';
        return;
      }

      const items = (data.items || []).slice(0, 10);
      const base = (data.imagesBaseUrl || '').replace(/\/$/, '');

      if (!grid) return;
      grid.innerHTML = '';

      if (!items.length){
        grid.innerHTML = `<div class="text-muted small">Aucune nouveauté.</div>`;
        return;
      }

      const cartObj = getCart();

      items.forEach(a => {
        const uid = a.UniqueId || '';
        const code = String(a.Id || '');
        const desFull = a.DesComClear || '';
        const des = truncate(desFull, 30);

        const img = (base && uid) ? (base + '/' + uid + '.png') : DEFAULT_IMG;

        const stock = Math.max(0, Number(a.RealStock || 0));
        const stockDisplay = (stock > 20) ? '+20' : String(stock);

        const inCartQty = getCartQtyFromObj(cartObj, code);

        // ✅ dans "Nouveautés" => badge toujours affiché
        const isNew = (a.isNew !== undefined) ? !!a.isNew : true;

        const card = document.createElement('div');
        card.className = 'product-card';
        card.setAttribute('data-card-code', code);

        card.innerHTML = `
          <div class="wishlist-button" title="Stock" style="${stockStyle(stock)}">
            <span style="font-weight:950; font-size:.92rem; line-height:1;">${esc(stockDisplay)}</span>
          </div>

          <div class="product-card__image">
            <div class="badge-pill" title="Dans le panier">
              <i class="fa fa-shopping-basket"></i>
              <span data-cart-qty>${esc(inCartQty)}</span>
            </div>

            ${isNew ? `<div class="badge-newimg" title="Nouveauté" aria-hidden="true">
              <img src="${NEW_BADGE_IMG}" alt="Nouveauté">
            </div>` : ''}

            <img class="product-img" src="${esc(img)}" alt="${esc(code)}"
                 onerror="this.onerror=null;this.src='${esc(DEFAULT_IMG)}'">
          </div>

          <div class="product-card__info">
            <div class="refPlusCopy">
              <a href="javascript:void(0)" class="product-reference text-primary">${esc(code)}</a>
              <span class="copy-icon" title="Copier" style="cursor:pointer">
                <i class="fa-solid fa-copy"></i>
              </span>
            </div>

            <a href="javascript:void(0)" class="designation" title="${esc(desFull)}">${esc(des)}</a>

            <div class="meta-line">
              ${a.xx_Marque ? `<span class="meta-chip">${esc(a.xx_Marque)}</span>` : ''}
            </div>
          </div>

          <div class="product-card__footer">
            <div class="product-card__prices">
              <span class="price-ttc">${money(a.SalePriceVatIncluded)} DH</span>
              <span class="price-label">[TTC]</span>
            </div>

            <div class="bottomFooterWrapper">
              <div class="qty-stepper" data-qty-stepper>
                <button class="qty-btn" type="button" data-qty-minus aria-label="Diminuer">
                  <i class="fa-solid fa-minus"></i>
                </button>

                <input class="qty-field" type="text" inputmode="numeric" value="1" data-qty-input>

                <button class="qty-btn" type="button" data-qty-plus aria-label="Augmenter">
                  <i class="fa-solid fa-plus"></i>
                </button>
              </div>

              <button class="addcart" type="button" title="Ajouter au panier">
                <i class="fa-solid fa-cart-plus"></i>
              </button>
            </div>

            <div class="small text-danger mt-2 d-none" data-stock-msg></div>
          </div>
        `;

        // copier ref
        card.querySelector('.copy-icon')?.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(code); } catch {}
        });

        const cartQtyEl = card.querySelector('[data-cart-qty]');
        const qtyField  = card.querySelector('[data-qty-input]');
        const btnMinus  = card.querySelector('[data-qty-minus]');
        const btnPlus   = card.querySelector('[data-qty-plus]');
        const addBtn    = card.querySelector('.addcart');
        const msgEl     = card.querySelector('[data-stock-msg]');

        const showMsg = (text)=>{
          if (!msgEl) return;
          msgEl.textContent = text;
          msgEl.classList.remove('d-none');
          clearTimeout(msgEl._t);
          msgEl._t = setTimeout(()=> msgEl.classList.add('d-none'), 1800);
        };

        const getAvailNow = ()=>{
          const currentInCart = parseInt(cartQtyEl?.textContent || '0', 10) || 0;
          return Math.max(0, stock - currentInCart);
        };

        const sanitizeQty = ()=>{
          if (!qtyField) return 1;
          qtyField.value = (qtyField.value || '').replace(/\D+/g,'') || '1';
          let v = parseInt(qtyField.value, 10);
          if (!isFinite(v) || v < 1) v = 1;
          return v;
        };

        const setUI = ()=>{
          const max = getAvailNow();

          let v = sanitizeQty();
          if (max > 0) v = Math.min(v, max);
          if (qtyField) qtyField.value = String(v);

          const disabledAll = (max <= 0);
          if (qtyField) qtyField.disabled = disabledAll;
          if (addBtn) addBtn.disabled = disabledAll;

          if (btnMinus) btnMinus.disabled = disabledAll || v <= 1;
          if (btnPlus)  btnPlus.disabled  = disabledAll || v >= max;
        };

        // expose updater for global refresh
        card._updateUI = setUI;

        btnMinus?.addEventListener('click', ()=>{
          const cur = sanitizeQty();
          if (qtyField) qtyField.value = String(Math.max(1, cur - 1));
          setUI();
        });

        btnPlus?.addEventListener('click', ()=>{
          const cur = sanitizeQty();
          if (qtyField) qtyField.value = String(cur + 1);
          setUI();
        });

        qtyField?.addEventListener('input', ()=>{
          sanitizeQty();
          setUI();
        });

        addBtn?.addEventListener('click', async ()=>{
          setUI();
          const max = getAvailNow();

          if (max <= 0){
            showMsg('Stock indisponible.');
            return;
          }

          const qty = Math.max(1, sanitizeQty());
          if (qty > max){
            showMsg(`Stock dispo: ${max}`);
            if (qtyField) qtyField.value = String(max);
            setUI();
            return;
          }

          const oldHtml = addBtn.innerHTML;
          addBtn.disabled = true;
          addBtn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>`;

          try{
            const resAdd = await fetch('/api/cart/add', {
              method: 'POST',
              headers: { 'Content-Type':'application/json', 'Accept':'application/json' },
              body: JSON.stringify({ code, qty })
            });

            if (resAdd.status === 401){
              showMsg('Connectez-vous pour ajouter au panier.');
              setUI();
              return;
            }

            if (resAdd.ok){
              const freshCart = getCart();
              const current = parseInt(cartQtyEl?.textContent || '0', 10) || 0;
              const next = Math.min(current + qty, stock);

              setCartQtyInObj(freshCart, code, next);
              setCart(freshCart, {emit:true});

              if (cartQtyEl) cartQtyEl.textContent = String(next);
              if (qtyField) qtyField.value = '1';

              setUI();
              if (getAvailNow() <= 0) showMsg('Stock épuisé pour cet article.');
            } else {
              showMsg('Erreur ajout panier.');
              setUI();
            }
          } catch(e){
            showMsg('Erreur réseau.');
            setUI();
          } finally {
            addBtn.innerHTML = oldHtml;
            addBtn.disabled = (getAvailNow() <= 0);
            setUI();
          }
        });

        setUI();
        grid.appendChild(card);
      });

      // au cas où panier vidé juste après render
      refreshBadges();

    } catch(e){
      if (err){
        err.classList.remove('d-none');
        err.innerHTML = `<div class="fw-bold">Erreur JS</div><div class="small">${esc(e.message || e)}</div>`;
      }
      if (grid) grid.innerHTML = '';
      console.error(e);
    }
  }

  loadNew();
})();
</script>