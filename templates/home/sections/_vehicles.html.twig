{# templates/home/sections/_vehicles.html.twig #}

<style>
  /* ===== Vehicles : UX pro / cards clean ===== */
  :root{
    --v-r: 18px;
    --v-bd: rgba(16,24,40,.10);
    --v-bg: rgba(255,255,255,.88);
    --v-text: rgba(16,24,40,.92);
    --v-muted: rgba(16,24,40,.62);
    --v-shadow: 0 10px 28px rgba(16,24,40,.08);
    --v-shadow-h: 0 18px 48px rgba(16,24,40,.14);
  }
  body.theme-dark{
    --v-bd: rgba(255,255,255,.14);
    --v-bg: rgba(18,18,22,.72);
    --v-text: rgba(255,255,255,.92);
    --v-muted: rgba(255,255,255,.62);
    --v-shadow: 0 16px 46px rgba(0,0,0,.40);
    --v-shadow-h: 0 22px 64px rgba(0,0,0,.55);
  }

  .vehicle-card{
    position: relative;
    display:block;
    width:100%;
    text-decoration:none;
    border-radius: var(--v-r);
    border: 1px solid var(--v-bd);
    background: var(--v-bg);
    box-shadow: var(--v-shadow);
    overflow:hidden;
    padding: 12px 12px 12px 12px;
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease, background .15s ease;
    color: var(--v-text);
  }

  .vehicle-card:hover{
    transform: translateY(-3px);
    border-color: rgba(220,53,69,.28);
    box-shadow: var(--v-shadow-h);
    background:
      radial-gradient(700px circle at 10% 10%, rgba(220,53,69,.10), transparent 45%),
      var(--v-bg);
  }

  .vehicle-card:focus-visible{
    outline: 3px solid rgba(13,110,253,.25);
    outline-offset: 2px;
  }

  /* Badge count en haut */
  .vehicle-badge{
    position:absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    display:inline-flex;
    align-items:center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(16,24,40,.12);
    background: rgba(255,255,255,.82);
    color: rgba(16,24,40,.78);
    font-weight: 950;
    font-size: .76rem;
    backdrop-filter: blur(8px);
    line-height: 1;
  }
  body.theme-dark .vehicle-badge{
    border-color: rgba(255,255,255,.14);
    background: rgba(18,18,22,.78);
    color: rgba(255,255,255,.78);
  }
  .vehicle-badge .n{ color: rgba(220,53,69,.95); }

  /* Layout intérieur */
  .vehicle-row{
    display:flex;
    align-items:center;
    gap: 10px;
    padding-top: 18px; /* laisse respirer sous le badge */
    min-height: 58px;
  }

  .vehicle-name{
    flex: 1;
    font-weight: 950;
    font-size: .95rem;
    line-height: 1.1;
    color: var(--v-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Logo à droite (pastille) */
  .vehicle-logoWrap{
    width: 60px;
    height: 60px;
    border-radius: 16px;
    border: 1px solid rgba(16,24,40,.10);
    background: rgba(16,24,40,.04);
    display:grid;
    place-items:center;
    flex: 0 0 auto;
  }
  body.theme-dark .vehicle-logoWrap{
    border-color: rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
  }

  .vehicle-logo{
    width: 60px;
    height: 60px;
    object-fit: contain;
    filter: drop-shadow(0 10px 16px rgba(0,0,0,.10));
        border-radius: 13px;
  }
  body.theme-dark .vehicle-logo{
    filter: drop-shadow(0 16px 22px rgba(0,0,0,.45));
  }

  /* Petit hint sous le nom */
  .vehicle-sub{
    margin-top: 6px;
    font-size: .78rem;
    color: var(--v-muted);
    font-weight: 800;
  }

  /* Skeleton */
  .vehicle-skeleton{
    border-radius: var(--v-r);
    height: 78px;
    background: linear-gradient(90deg, rgba(16,24,40,.04), rgba(16,24,40,.08), rgba(16,24,40,.04));
    background-size: 200% 100%;
    animation: sk 1.2s infinite;
    border: 1px solid rgba(16,24,40,.06);
    box-shadow: 0 10px 26px rgba(16,24,40,.06);
  }
  body.theme-dark .vehicle-skeleton{
    background: linear-gradient(90deg, rgba(255,255,255,.05), rgba(255,255,255,.09), rgba(255,255,255,.05));
    border-color: rgba(255,255,255,.10);
    box-shadow: 0 16px 40px rgba(0,0,0,.35);
  }
  @keyframes sk { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  @media (prefers-reduced-motion: reduce){
    .vehicle-card{ transition:none !important; }
    .vehicle-skeleton{ animation:none !important; }
  }
</style>

<section class="facet-block mb-3" data-vehicle-section>
  <div class="facet-head">
    <div class="facet-title">
      <div class="facet-icon" style="background: rgba(220,53,69,.10); border-color: rgba(220,53,69,.20);">🚗</div>
      <div>
        <div class="fw-bold">Explorer par Véhicule</div>
        <div class="facet-sub" style="color: rgba(0,0,0,.55); font-size:.92rem;">
          Clique sur un véhicule pour ouvrir les articles filtrés.
        </div>
      </div>
    </div>
  </div>

  <div class="facet-body">
    <div class="row g-2" data-vehicle-grid>
      {# Skeletons #}
      {% for i in 1..18 %}
        <div class="col-6 col-md-4 col-lg-2">
          <div class="vehicle-skeleton"></div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function(){
  const section = document.querySelector('[data-vehicle-section]');
  if (!section) return;

  const grid = section.querySelector('[data-vehicle-grid]');
  const articlesUrl = "{{ path('articles_page')|e('js') }}";

  const IMG_DIR = "{{ asset('img')|e('js') }}".replace(/\/$/, '');
  const DEFAULT_IMG = "{{ asset('img/default.png')|e('js') }}";

  function esc(s){
    return String(s ?? '').replace(/[&<>"']/g, m => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[m]));
  }

  function prettify(v){
    if (!v) return '';
    let s = String(v).trim();
    s = s.replace(/_/g, ' ').replace(/\s+/g, ' ');
    s = s.toLowerCase().replace(/\b\w/g, m => m.toUpperCase());
    return s;
  }

  // ✅ Range Rover -> range_rover.png (minuscule, espaces => _, sans accents)
  function fileNameFromVehicle(v){
    let s = String(v || '').trim();

    // enlève accents
    try { s = s.normalize('NFD').replace(/[\u0300-\u036f]/g, ''); } catch(e){}

    s = s.toLowerCase();
    s = s.replace(/&/g, 'and');
    s = s.replace(/[^a-z0-9]+/g, '_'); // tout ce qui n'est pas alphanum => _
    s = s.replace(/^_+|_+$/g, '');
    if (!s) return '';
    return s + '.png';
  }

  async function loadVehicles(){
    try{
      const res = await fetch('/api/catalog/vehicles', { headers: { 'Accept': 'application/json' } });
      const data = await res.json().catch(()=> ({}));
      if (!res.ok || !data.ok) throw new Error(data.message || 'Erreur API vehicles');

      const items = (data.items || [])
        .filter(x => x && x.value)
        .sort((a,b)=> (b.count||0) - (a.count||0));

      grid.innerHTML = '';

      if (!items.length){
        grid.innerHTML = `<div class="text-muted small">Aucun véhicule trouvé.</div>`;
        return;
      }

      items.forEach(it => {
        const v = it.value;
        const count = it.count ?? 0;
        const href = `${articlesUrl}?vehicle=${encodeURIComponent(v)}`;

        const file = fileNameFromVehicle(v);
        const logo = file ? (IMG_DIR + '/' + file) : DEFAULT_IMG;

        const col = document.createElement('div');
        col.className = 'col-6 col-md-4 col-lg-2';

        col.innerHTML = `
          <a class="vehicle-card" href="${href}">
            <span class="vehicle-badge" title="Nombre d'articles">
              <span class="n">${esc(count)}</span>
              <span>art.</span>
            </span>

            <div class="vehicle-row">
              <div style="flex:1; min-width:0;">
                <div class="vehicle-name">${esc(prettify(v))}</div>
                <div class="vehicle-sub">Voir les articles →</div>
              </div>

              <div class="vehicle-logoWrap" aria-hidden="true">
                <img class="vehicle-logo"
                     src="${esc(logo)}"
                     alt=""
                     loading="lazy"
                     onerror="this.onerror=null;this.src='${esc(DEFAULT_IMG)}'">
              </div>
            </div>
          </a>
        `;
        grid.appendChild(col);
      });

    } catch(e){
      grid.innerHTML = `<div class="text-danger small">Impossible de charger les véhicules.</div>`;
      console.error(e);
    }
  }

  loadVehicles();
})();
</script>