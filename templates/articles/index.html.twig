{% extends 'base.html.twig' %}

{% block body %}

  {% set initial = initial|default({
    q: app.request.query.get('q', ''),
    family: app.request.query.get('family', ''),
    brand: app.request.query.get('brand', app.request.query.get('marque', '')),
    vehicle: app.request.query.get('vehicle', app.request.query.get('vehicule', '')),
    anneeFrom: app.request.query.get('anneeFrom', ''),
    anneeTo: app.request.query.get('anneeTo', ''),
    annee: app.request.query.get('annee', ''),
    inStock: app.request.query.get('inStock', ''),
    new: app.request.query.get('new', ''),
    newDays: (app.request.query.get('newDays', 5))
  }) %}

  {# ✅ Slider 2 poignées (1 seule barre) #}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/nouislider@15.7.1/dist/nouislider.min.css">
  <script src="https://cdn.jsdelivr.net/npm/nouislider@15.7.1/dist/nouislider.min.js"></script>

  <style>
    :root{
      --pc-radius: 18px;
      --pc-border: rgba(0,0,0,.10);
      --pc-shadow: 0 14px 34px rgba(0,0,0,.08);
      --pc-muted: rgba(0,0,0,.58);
    }
    body.theme-dark{
      --pc-border: rgba(255,255,255,.14);
      --pc-shadow: 0 18px 46px rgba(0,0,0,.35);
      --pc-muted: rgba(255,255,255,.65);
    }

    .page-hero{
      border-radius: 22px;
      border: 1px solid var(--pc-border);
      box-shadow: var(--pc-shadow);
      padding: 16px;
      background:
        radial-gradient(900px circle at 10% 10%, rgba(13,110,253,.16), transparent 40%),
        radial-gradient(900px circle at 90% 30%, rgba(25,135,84,.14), transparent 38%),
        linear-gradient(180deg, rgba(0,0,0,.02), transparent);
    }

    .filters-card{
      border-radius: 22px;
      border: 1px solid var(--pc-border);
      box-shadow: var(--pc-shadow);
      background: rgba(255,255,255,.75);
      backdrop-filter: blur(8px);
    }
    body.theme-dark .filters-card{ background: rgba(18,18,22,.62); }

    .product-grid{
      display:grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 14px;
    }
    @media (min-width: 768px){
      .product-grid{ grid-template-columns: repeat(3, minmax(0,1fr)); }
    }
    @media (min-width: 1200px){
      .product-grid{ grid-template-columns: repeat(4, minmax(0,1fr)); }
    }

    .product-card{
      position: relative;
      border-radius: var(--pc-radius);
      border: 1px solid var(--pc-border);
      box-shadow: 0 10px 24px rgba(0,0,0,.06);
      background: rgba(255,255,255,.85);
      overflow: hidden;
      transition: transform .08s ease, box-shadow .12s ease, border-color .12s ease;
    }
    body.theme-dark .product-card{ background: rgba(18,18,22,.70); }

    .product-card:hover{
      transform: translateY(-2px);
      box-shadow: 0 16px 32px rgba(0,0,0,.10);
      border-color: rgba(13,110,253,.22);
    }

    .wishlist-button{
      position:absolute;
      top:10px; right:10px;
      width: 40px; height: 40px;
      border-radius: 14px;
      border: 1px solid var(--pc-border);
      background: rgba(255,255,255,.82);
      display:grid; place-items:center;
      z-index: 5;
    }
    body.theme-dark .wishlist-button{ background: rgba(18,18,22,.72); }

    .product-card__image{
      position: relative;
      padding: 14px;
      background: linear-gradient(180deg, rgba(0,0,0,.02), transparent);
    }

    .badge-pill{
      position:absolute;
      left: 12px;
      top: 12px;
      display:flex; align-items:center; gap:6px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.80);
      font-weight: 900;
      font-size: .78rem;
      z-index: 4;
    }
    body.theme-dark .badge-pill{
      border-color: rgba(255,255,255,.14);
      background: rgba(18,18,22,.70);
    }

    .badge-newimg{
      position: absolute;
      top: 7px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 6;
      pointer-events: none;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .badge-newimg img{
      width: min(220px, 100%);
      height: auto;
      filter: drop-shadow(0 10px 18px rgba(0,0,0,.18));
    }
    body.theme-dark .badge-newimg img{
      filter: drop-shadow(0 14px 24px rgba(0,0,0,.55));
    }

    .product-img{
      width: 100%;
      aspect-ratio: 1/1;
      object-fit: contain;
      border-radius: 16px;
      background: rgba(255,255,255,.35);
      padding: 12px;
      border: 1px solid rgba(0,0,0,.06);
    }
    body.theme-dark .product-img{ background: rgba(255,255,255); border-color: rgba(255,255,255,.10); }

    .product-card__info{ padding: 12px 14px 0 14px; }

    .refPlusCopy{
      display:flex; align-items:center; gap:8px;
      font-weight: 900;
      font-size: .95rem;
    }
    .product-reference{ text-decoration:none; color: inherit; }

    .designation{
      display:block;
      margin-top: 6px;
      font-weight: 800;
      font-size: .92rem;
      color: rgba(0,0,0,.75);
      text-decoration:none;
    }
    body.theme-dark .designation{ color: rgba(255,255,255,.86); }

    .meta-line{
      margin-top: 8px;
      font-size: .80rem;
      color: var(--pc-muted);
      display:flex;
      flex-wrap:wrap;
      gap: 8px;
    }
    .meta-chip{
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.7);
      border-radius: 999px;
      padding: 4px 8px;
      font-weight: 800;
    }
    body.theme-dark .meta-chip{
      border-color: rgba(255,255,255,.14);
      background: rgba(18,18,22,.62);
    }

    .product-card__footer{ padding: 12px 14px 14px 14px; }

    .product-card__prices{
      display:flex;
      align-items:baseline;
      gap: 8px;
      font-weight: 950;
    }
    .price-ttc{ font-size: 1.05rem; }
    .price-label{ font-size: .78rem; color: var(--pc-muted); font-weight: 900; }

    .bottomFooterWrapper{
      margin-top: 10px;
      display:flex;
      align-items:center;
      gap: 10px;
    }

    .addcart{
      margin-left:auto;
      width: 44px; height: 44px;
      border-radius: 10px;
      display:grid; place-items:center;
      border: 1px solid rgba(13,110,253,.25);
      background: rgba(13,110,253,.10);
    }
    .addcart:hover{ background: rgba(13,110,253,.16); }
    .addcart:disabled{
      opacity: .55;
      cursor: not-allowed;
      background: rgba(0,0,0,.06);
      border-color: rgba(0,0,0,.10);
    }

    .skeleton{
      height: 380px;
      border-radius: var(--pc-radius);
      border: 1px solid rgba(0,0,0,.06);
      background: linear-gradient(90deg, rgba(0,0,0,.04), rgba(0,0,0,.08), rgba(0,0,0,.04));
      background-size: 200% 100%;
      animation: sk 1.2s infinite;
    }
    @keyframes sk { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* ✅ Slider 1 barre / 2 poignées */
    #yearSlider{ margin-top: 8px; margin-bottom: 10px; }
    .noUi-target{
      border: 1px solid var(--pc-border);
      border-radius: 999px;
      box-shadow: none;
      background: rgba(0,0,0,.05);
      height: 10px;
    }
    body.theme-dark .noUi-target{ background: rgba(255,255,255,.10); }
    .noUi-connect{ background: rgba(13,110,253,.45); }
    .noUi-handle{
      width: 22px !important;
      height: 22px !important;
      border-radius: 999px !important;
      border: 1px solid var(--pc-border) !important;
      background: rgba(255,255,255,.98) !important;
      box-shadow: 0 10px 20px rgba(0,0,0,.12) !important;
      top: -7px !important;
      right: -11px !important;
    }
    body.theme-dark .noUi-handle{
      background: rgba(18,18,22,.92) !important;
      box-shadow: 0 16px 32px rgba(0,0,0,.35) !important;
    }
    .noUi-handle:before,
    .noUi-handle:after{ display:none !important; }

    /* ✅ Quantité (comme la photo) */
    .qty-stepper{
      display:flex;
      align-items:stretch;
      height: 44px;
      border: 1px solid var(--pc-border);
      border-radius: 10px;
      overflow: hidden;
      background: rgba(255,255,255,.92);
      flex: 0 0 auto;
    }
    body.theme-dark .qty-stepper{ background: rgba(18,18,22,.70); }

    .qty-btn{
      width: 44px;
      border: 0;
      background: transparent;
      display:grid;
      place-items:center;
      font-weight: 900;
      color: rgba(0,0,0,.65);
      transition: background .12s ease, color .12s ease;
      flex: 0 0 44px;
    }
    body.theme-dark .qty-btn{ color: rgba(255,255,255,.75); }

    .qty-btn:hover{ background: rgba(0,0,0,.05); }
    body.theme-dark .qty-btn:hover{ background: rgba(255,255,255,.06); }

    .qty-btn:disabled{
      opacity: .45;
      cursor: not-allowed;
    }

    .qty-field{
      width: 56px;
      border: 0;
      outline: none;
      text-align: center;
      font-weight: 950;
      background: transparent;
      color: rgba(0,0,0,.85);
      flex: 0 0 56px;
    }
    body.theme-dark .qty-field{ color: rgba(255,255,255,.90); }
    .qty-field:disabled{ opacity: .6; }
  </style>

  <div class="container py-4"
       data-initial='{{ initial|json_encode(constant("JSON_UNESCAPED_UNICODE"))|e("html_attr") }}'>

    <div class="page-hero mb-3 d-flex align-items-start justify-content-between flex-wrap gap-2">
      <div>
        <h3 class="mb-1">Articles</h3>
        <div class="text-muted small">
          Recherche instantanée + filtres.
          {% if initial.new == '1' %}
            <span class="badge text-bg-success ms-2">Nouveautés ({{ initial.newDays }}j)</span>
          {% endif %}
        </div>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="{{ path('articles_page') }}">Reset</a>
        <a class="btn btn-outline-primary" href="{{ path('articles_page', { new: 1, newDays: 5 }) }}">
          Nouveautés (5j)
        </a>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-3">
        <div class="filters-card p-3">
          <div class="fw-bold mb-2">Filtres</div>

          <div class="mb-2">
            <label class="form-label small mb-1">Recherche</label>
            <input class="form-control form-control-sm" id="f_q" placeholder="Mot-clé / référence...">
          </div>

          <div class="mb-2">
            <label class="form-label small mb-1">Famille</label>
            <select class="form-select form-select-sm" id="f_family">
              <option value="">Toutes</option>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label small mb-1">Marque</label>
            <select class="form-select form-select-sm" id="f_brand">
              <option value="">Toutes</option>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label small mb-1">Véhicule</label>
            <select class="form-select form-select-sm" id="f_vehicle">
              <option value="">Tous</option>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label small mb-1 d-flex align-items-center justify-content-between">
              <span>Année</span>
              <span class="badge text-bg-secondary" id="anneeBadge">—</span>
            </label>

            <div id="yearSlider"></div>
            <input type="hidden" id="f_yearFrom" value="1976">
            <input type="hidden" id="f_yearTo" value="2030">

            <div class="progress" style="height:10px; border-radius:999px;">
              <div class="progress-bar" id="yearRangeBar" role="progressbar" style="width:100%"></div>
            </div>

            <div class="d-flex justify-content-between small text-muted mt-1">
              <span id="yearMinLabel">—</span>
              <span id="yearMaxLabel">—</span>
            </div>
          </div>

          <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" id="f_inStock">
            <label class="form-check-label small" for="f_inStock">En stock uniquement</label>
          </div>

          <div class="mt-3 d-grid gap-2">
            <button class="btn btn-primary btn-sm" id="applyFilters">Appliquer</button>
            <button class="btn btn-outline-secondary btn-sm" id="clearFilters">Effacer</button>
          </div>

          <div class="small text-muted mt-3" id="resultMeta">—</div>
        </div>
      </div>

      <div class="col-lg-9">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
          <div class="small text-muted" id="statusLine">—</div>

          <div class="d-flex gap-2 align-items-center flex-wrap">
            <div class="d-flex align-items-center gap-2">
              <span class="small text-muted">Articles / page :</span>
              <select class="form-select form-select-sm" id="limitSelect" style="width:auto;">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="24" selected>24</option>
                <option value="40">40</option>
                <option value="60">60</option>
              </select>
            </div>

            <button class="btn btn-outline-secondary btn-sm" id="prevBtn" disabled>←</button>
            <span class="small" id="pageLabel">1</span>
            <button class="btn btn-outline-secondary btn-sm" id="nextBtn" disabled>→</button>
          </div>
        </div>

        <div id="grid" class="product-grid"></div>
        <div class="alert alert-danger mt-3 d-none" id="apiError"></div>

        <div class="d-flex align-items-center justify-content-end flex-wrap gap-2 mt-3">
          <button class="btn btn-outline-secondary btn-sm" id="prevBtnBottom" disabled>←</button>
          <span class="small" id="pageLabelBottom">1</span>
          <button class="btn btn-outline-secondary btn-sm" id="nextBtnBottom" disabled>→</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function(){
      const wrap = document.querySelector('[data-initial]');
      const initial = safeJsonParse(wrap?.getAttribute('data-initial') || '{}', {});

      const f_q = document.getElementById('f_q');
      const f_family = document.getElementById('f_family');
      const f_brand = document.getElementById('f_brand');
      const f_vehicle = document.getElementById('f_vehicle');

      const f_yearFrom = document.getElementById('f_yearFrom');
      const f_yearTo = document.getElementById('f_yearTo');

      const anneeBadge = document.getElementById('anneeBadge');
      const yearRangeBar = document.getElementById('yearRangeBar');
      const yearMinLabel = document.getElementById('yearMinLabel');
      const yearMaxLabel = document.getElementById('yearMaxLabel');

      const yearSliderEl = document.getElementById('yearSlider');
      let yearSlider = null;

      const f_inStock = document.getElementById('f_inStock');

      const applyBtn = document.getElementById('applyFilters');
      const clearBtn = document.getElementById('clearFilters');
      const grid = document.getElementById('grid');

      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const pageLabel = document.getElementById('pageLabel');

      const prevBtnBottom = document.getElementById('prevBtnBottom');
      const nextBtnBottom = document.getElementById('nextBtnBottom');
      const pageLabelBottom = document.getElementById('pageLabelBottom');

      const limitSelect = document.getElementById('limitSelect');

      const statusLine = document.getElementById('statusLine');
      const resultMeta = document.getElementById('resultMeta');
      const apiError = document.getElementById('apiError');

      const FALLBACK_IMG = "{{ asset('img/default.png')|e('js') }}";
      const NEW_BADGE_IMG = "{{ asset('img/new.png')|e('js') }}";

      const DEFAULT_YEAR_MIN = 1976;
      let dataYearMin = DEFAULT_YEAR_MIN;
      let dataYearMax = 2030;
      let yearBoundsInitialized = false;

      let facetsLoaded = false;

      let state = {
        page: 1,
        limit: 24,
        q: initial.q || '',
        family: initial.family || '',
        brand: initial.brand || '',
        vehicle: initial.vehicle || '',
        inStock: initial.inStock || '',
        onlyNew: (initial.new === '1'),
        newDays: initial.newDays || 5,
      };

      // ========= Helpers =========
      function safeJsonParse(s, fallback){
        try { return JSON.parse(s); } catch(e){ return fallback; }
      }

      function esc(s){
        return String(s ?? '').replace(/[&<>"']/g, m => ({
          '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
        }[m]));
      }

      function money(v){
        const n = Number(String(v).replace(',', '.'));
        if (!isFinite(n)) return esc(v);
        return n.toFixed(2);
      }

      function truncate(s, max){
        s = String(s ?? '').trim();
        return (s.length <= max) ? s : (s.slice(0, max) + '…');
      }

      // ========= Cart (local) =========
      function normalizeCartObj(obj){
        if (!obj || typeof obj !== 'object') return {};
        const out = {};
        for (const [k, v] of Object.entries(obj)){
          if (!k) continue;
          if (typeof v === 'number') out[k] = Math.max(0, Math.floor(v));
          else if (v && typeof v === 'object' && v.qty != null) out[k] = { ...v, qty: Math.max(0, Math.floor(Number(v.qty) || 0)) };
          else out[k] = Math.max(0, Math.floor(Number(v) || 0));
        }
        return out;
      }

      function getCart(){
        const raw = safeJsonParse(localStorage.getItem('cart') || '{}', {});
        return normalizeCartObj(raw);
      }

      function getCartQtyFromObj(obj, code){
        const v = obj?.[code];
        if (v == null) return 0;
        if (typeof v === 'number') return v;
        if (typeof v === 'object' && v.qty != null) return Number(v.qty) || 0;
        return Number(v) || 0;
      }

      function setCartQtyInObj(obj, code, nextQty){
        const v = obj?.[code];
        if (v && typeof v === 'object') obj[code].qty = nextQty;
        else obj[code] = nextQty;
      }

      let _cartWriteGuard = false;

      function emitCartEvent(name){
        window.dispatchEvent(new CustomEvent(name));
      }

      function writeCart(obj, {emit=true, refreshHeader=true, eventName='cart:changed'} = {}){
        if (_cartWriteGuard) return;
        _cartWriteGuard = true;
        try{
          const normalized = normalizeCartObj(obj);
          localStorage.setItem('cart', JSON.stringify(normalized));
        } catch(e){}
        _cartWriteGuard = false;

        if (emit) emitCartEvent(eventName);

        if (refreshHeader && typeof window.refreshHeaderCounts === 'function'){
          // pas d'await : on veut juste déclencher la synchro header
          try { window.refreshHeaderCounts(); } catch(e){}
        }
      }

      function clearLocalCart({emit=true, refreshHeader=true} = {}){
        writeCart({}, {emit, refreshHeader, eventName:'cart:cleared'});
        // on envoie aussi cart:changed pour les listeners "généraux"
        if (emit) emitCartEvent('cart:changed');
      }

      // Met à jour tous les badges "dans le panier" + les stepper UI
      function refreshGridCartBadges(){
        if (!grid) return;
        const cart = getCart();

        grid.querySelectorAll('.product-card').forEach(card => {
          const code = card.dataset.code || '';
          if (!code) return;

          const qty = getCartQtyFromObj(cart, code);
          const badge = card.querySelector('[data-cart-qty]');
          if (badge) badge.textContent = String(qty);

          // chaque card garde un updater (défini dans render)
          if (typeof card._updateUI === 'function'){
            try { card._updateUI(); } catch(e){}
          }
        });
      }

      // ✅ si un autre endroit vide le panier (ou cart page)
      window.addEventListener('cart:cleared', () => {
        refreshGridCartBadges();
      });
      window.addEventListener('cart:changed', () => {
        refreshGridCartBadges();
      });

      // ✅ si localStorage change depuis un autre onglet/page
      window.addEventListener('storage', (e) => {
        if (!e || !e.key || e.key === 'cart'){
          refreshGridCartBadges();
        }
      });

      // ========= Sync server -> local (robuste quand on vide le panier ailleurs) =========
      let _syncingFromServer = false;

      async function syncCartFromServer({emit=true} = {}){
        if (_syncingFromServer) return;
        _syncingFromServer = true;
        try{
          const res = await fetch('/api/cart', { headers: { 'Accept':'application/json' } });
          if (res.status === 401){ _syncingFromServer = false; return; }
          const data = await res.json().catch(()=> ({}));
          if (!res.ok || !data || !data.ok){
            _syncingFromServer = false;
            return;
          }

          const serverObj = {};
          const items = data.items || [];
          items.forEach(it => {
            const code = it.code ?? it.id ?? it.Id ?? it.ID ?? it.ref ?? '';
            const qty = Number(it.qty ?? it.quantity ?? 0) || 0;
            if (code) serverObj[String(code)] = Math.max(0, Math.floor(qty));
          });

          // compare avec local (simple)
          const localObj = getCart();
          const a = JSON.stringify(normalizeCartObj(localObj));
          const b = JSON.stringify(normalizeCartObj(serverObj));

          if (a !== b){
            // IMPORTANT: pas de refreshHeader ici sinon boucle
            if (Object.keys(serverObj).length === 0) {
              writeCart({}, {emit, refreshHeader:false, eventName:'cart:cleared'});
              if (emit) emitCartEvent('cart:changed');
            } else {
              writeCart(serverObj, {emit, refreshHeader:false, eventName:'cart:changed'});
            }
          } else {
            // même contenu => juste rafraîchir l'UI si besoin
            if (emit) emitCartEvent('cart:changed');
          }
        } catch(e){
          // ignore
        } finally {
          _syncingFromServer = false;
        }
      }

      // Wrap refreshHeaderCounts (si présent) pour détecter un panier vidé côté serveur
      (function wrapHeaderRefresh(){
        if (typeof window.refreshHeaderCounts !== 'function') return;
        if (window._hopicWrappedRefreshHeaderCounts) return;

        const orig = window.refreshHeaderCounts;
        window.refreshHeaderCounts = async function(...args){
          const r = await orig.apply(this, args);
          // si le serveur a vidé le panier, on recopie dans localStorage
          await syncCartFromServer({emit:true});
          return r;
        };
        window._hopicWrappedRefreshHeaderCounts = true;
      })();

      // Sync quand on ferme l'offcanvas panier (si existant)
      (function bindOffcanvasSync(){
        const oc = document.getElementById('cartOffcanvas');
        if (!oc) return;
        oc.addEventListener('hidden.bs.offcanvas', () => {
          syncCartFromServer({emit:true});
        });
      })();

      // ========= Filters / UI init =========
      // init limit depuis URL ?limit=
      const limitFromQuery = parseInt(new URLSearchParams(window.location.search).get('limit') || '', 10);
      if (isFinite(limitFromQuery) && limitFromQuery > 0) state.limit = limitFromQuery;

      if (limitSelect) {
        const has = Array.from(limitSelect.options).some(o => Number(o.value) === Number(state.limit));
        if (!has) state.limit = 24;
        limitSelect.value = String(state.limit);

        limitSelect.addEventListener('change', () => {
          const v = parseInt(limitSelect.value || '24', 10);
          state.limit = (isFinite(v) && v > 0) ? v : 24;
          state.page = 1;
          syncUrlToBrowser();
          load();
        });
      }

      if (f_q) f_q.value = state.q;
      if (f_inStock) f_inStock.checked = (state.inStock === '1');

      function skeletons(){
        if (!grid) return;
        grid.innerHTML = '';
        for (let i=0; i<8; i++){
          const d = document.createElement('div');
          d.className = 'skeleton';
          grid.appendChild(d);
        }
      }

      // ========= Année (noUiSlider) =========
      function clampYears(from, to){
        from = Math.max(dataYearMin, Math.min(dataYearMax, from));
        to   = Math.max(dataYearMin, Math.min(dataYearMax, to));
        if (from > to) { const t = from; from = to; to = t; }
        return { from, to };
      }

      function updateYearUI(from, to){
        if (yearMinLabel) yearMinLabel.textContent = String(dataYearMin);
        if (yearMaxLabel) yearMaxLabel.textContent = String(dataYearMax);

        if (anneeBadge){
          if (from === dataYearMin && to === dataYearMax) anneeBadge.textContent = 'Tout';
          else if (from === to) anneeBadge.textContent = String(from);
          else anneeBadge.textContent = `${from} → ${to}`;
        }

        const range = (dataYearMax - dataYearMin) || 1;
        const leftPct = ((from - dataYearMin) / range) * 100;
        const rightPct = ((to - dataYearMin) / range) * 100;

        if (yearRangeBar){
          yearRangeBar.style.marginLeft = leftPct + '%';
          yearRangeBar.style.width = Math.max(0, rightPct - leftPct) + '%';
        }
      }

      function setYearValues(from, to, syncSlider=true){
        const c = clampYears(parseInt(from, 10), parseInt(to, 10));
        if (f_yearFrom) f_yearFrom.value = String(c.from);
        if (f_yearTo)   f_yearTo.value   = String(c.to);
        updateYearUI(c.from, c.to);

        if (syncSlider && yearSlider){
          yearSlider.set([c.from, c.to]);
        }
      }

      function ensureYearSlider(){
        if (!yearSliderEl || yearSlider) return;
        if (typeof noUiSlider === 'undefined') return;

        noUiSlider.create(yearSliderEl, {
          start: [dataYearMin, dataYearMax],
          connect: true,
          step: 1,
          range: { min: dataYearMin, max: dataYearMax },
          format: { to: v => String(Math.round(v)), from: v => Number(v) }
        });

        yearSlider = yearSliderEl.noUiSlider;

        yearSlider.on('update', (values) => {
          const from = parseInt(values[0], 10);
          const to   = parseInt(values[1], 10);
          if (f_yearFrom) f_yearFrom.value = String(from);
          if (f_yearTo)   f_yearTo.value   = String(to);
          updateYearUI(from, to);
        });
      }

      function updateYearSliderOptions(){
        ensureYearSlider();
        if (!yearSlider) {
          setYearValues(f_yearFrom?.value || dataYearMin, f_yearTo?.value || dataYearMax, false);
          return;
        }

        yearSlider.updateOptions({ range: { min: dataYearMin, max: dataYearMax } });
        setYearValues(f_yearFrom?.value || dataYearMin, f_yearTo?.value || dataYearMax, true);
      }

      function initYearFromQuery(){
        let from = initial.anneeFrom ? parseInt(initial.anneeFrom, 10) : NaN;
        let to   = initial.anneeTo   ? parseInt(initial.anneeTo, 10)   : NaN;

        if ((!isFinite(from) || !isFinite(to)) && initial.annee){
          const y = parseInt(initial.annee, 10);
          if (isFinite(y)){ from = y; to = y; }
        }

        if (!isFinite(from)) from = dataYearMin;
        if (!isFinite(to))   to   = dataYearMax;

        setYearValues(from, to, true);
      }

      // ========= URL build/sync =========
      function buildUrl(){
        const url = new URL('/api/articles', window.location.origin);
        url.searchParams.set('page', String(state.page));
        url.searchParams.set('limit', String(state.limit));

        if (state.q) url.searchParams.set('q', state.q);
        if (state.family) url.searchParams.set('family', state.family);
        if (state.brand) url.searchParams.set('brand', state.brand);
        if (state.vehicle) url.searchParams.set('vehicle', state.vehicle);
        if (state.inStock === '1') url.searchParams.set('inStock', '1');

        const from = parseInt(f_yearFrom?.value || String(dataYearMin), 10);
        const to   = parseInt(f_yearTo?.value   || String(dataYearMax), 10);
        const isAll = (from === dataYearMin && to === dataYearMax);
        if (!isAll){
          url.searchParams.set('anneeFrom', String(from));
          url.searchParams.set('anneeTo', String(to));
        }

        if (state.onlyNew) {
          url.searchParams.set('new', '1');
          url.searchParams.set('newDays', String(state.newDays));
        }

        if (!facetsLoaded) url.searchParams.set('facets', '1');
        return url.toString();
      }

      function syncUrlToBrowser(){
        const url = new URL('{{ path("articles_page") }}', window.location.origin);

        if (state.q) url.searchParams.set('q', state.q);
        if (state.family) url.searchParams.set('family', state.family);
        if (state.brand) url.searchParams.set('brand', state.brand);
        if (state.vehicle) url.searchParams.set('vehicle', state.vehicle);
        if (state.inStock === '1') url.searchParams.set('inStock', '1');

        const from = parseInt(f_yearFrom?.value || String(dataYearMin), 10);
        const to   = parseInt(f_yearTo?.value   || String(dataYearMax), 10);
        const isAll = (from === dataYearMin && to === dataYearMax);
        if (!isAll){
          url.searchParams.set('anneeFrom', String(from));
          url.searchParams.set('anneeTo', String(to));
        }

        if (state.onlyNew) {
          url.searchParams.set('new', '1');
          url.searchParams.set('newDays', String(state.newDays));
        }

        if (state.limit && state.limit !== 24) url.searchParams.set('limit', String(state.limit));
        else url.searchParams.delete('limit');

        history.replaceState({}, '', url.toString());
      }

      // ========= Render =========
      function stockStyle(stock){
        if (stock === 0) return `border-color: rgba(220,53,69,.30); background: rgba(220,53,69,.16); color: rgba(220,53,69,.98);`;
        if (stock < 5)  return `border-color: rgba(255,193,7,.40); background: rgba(255,193,7,.18); color: rgba(176,117,0,.98);`;
        if (stock > 10) return `border-color: rgba(25,135,84,.30); background: rgba(25,135,84,.16); color: rgba(25,135,84,.98);`;
        return ``;
      }

      function render(items, imagesBaseUrl){
        if (!grid) return;

        const cartObj = getCart();
        grid.innerHTML = '';

        if (!items || !items.length){
          grid.innerHTML = `<div class="text-muted small">Aucun article trouvé.</div>`;
          return;
        }

        const base = (imagesBaseUrl || '').replace(/\/$/, '');

        items.forEach(a => {
          const uid = a.UniqueId;
          const code = a.Id;
          const desFull = a.DesComClear || '';
          const des = truncate(desFull, 30);

          const img = (base && uid) ? (base + '/' + uid + '.png') : FALLBACK_IMG;

          const stock = Math.max(0, Number(a.RealStock || 0));
          const stockDisplay = (stock > 20) ? '+20' : String(stock);
          const isNew = !!a.isNew;

          const inCartQty = getCartQtyFromObj(cartObj, code);

          const card = document.createElement('div');
          card.className = 'product-card';
          card.dataset.code = String(code || '');
          card.dataset.stock = String(stock);

          card.innerHTML = `
            <div class="wishlist-button" title="Stock" style="${stockStyle(stock)}">
              <span style="font-weight:950; font-size:.92rem; line-height:1;">${esc(stockDisplay)}</span>
            </div>

            <div class="product-card__image">
              <div class="badge-pill" title="Dans le panier">
                <i class="fa fa-shopping-basket"></i>
                <span data-cart-qty>${esc(inCartQty)}</span>
              </div>

              ${isNew ? `<div class="badge-newimg" title="Nouveauté" aria-hidden="true">
                <img src="${NEW_BADGE_IMG}" alt="Nouveauté">
              </div>` : ''}

              <img class="product-img" src="${esc(img)}" alt="${esc(code)}"
                   onerror="this.onerror=null;this.src='${FALLBACK_IMG}'">
            </div>

            <div class="product-card__info">
              <div class="refPlusCopy">
                <a href="javascript:void(0)" class="product-reference text-primary">${esc(code)}</a>
                <span class="copy-icon" title="Copier" style="cursor:pointer">
                  <i class="fa-solid fa-copy"></i>
                </span>
              </div>

              <a href="javascript:void(0)" class="designation" title="${esc(desFull)}">${esc(des)}</a>

              <div class="meta-line">
                ${a.xx_Marque ? `<span class="meta-chip">${esc(a.xx_Marque)}</span>` : ''}
              </div>
            </div>

            <div class="product-card__footer">
              <div class="product-card__prices">
                <span class="price-ttc">${money(a.SalePriceVatIncluded)} DH</span>
                <span class="price-label">[TTC]</span>
              </div>

              <div class="bottomFooterWrapper">
                <div class="qty-stepper" data-qty-stepper>
                  <button class="qty-btn" type="button" data-qty-minus aria-label="Diminuer">
                    <i class="fa-solid fa-minus"></i>
                  </button>

                  <input class="qty-field" type="text" inputmode="numeric" value="1" data-qty-input>

                  <button class="qty-btn" type="button" data-qty-plus aria-label="Augmenter">
                    <i class="fa-solid fa-plus"></i>
                  </button>
                </div>

                <button class="addcart" type="button" title="Ajouter au panier">
                  <i class="fa-solid fa-cart-plus"></i>
                </button>
              </div>

              <div class="small text-danger mt-2 d-none" data-stock-msg></div>
            </div>
          `;

          // copy
          card.querySelector('.copy-icon')?.addEventListener('click', async () => {
            try { await navigator.clipboard.writeText(String(code || '')); } catch {}
          });

          const cartQtyEl = card.querySelector('[data-cart-qty]');
          const qtyField  = card.querySelector('[data-qty-input]');
          const btnMinus  = card.querySelector('[data-qty-minus]');
          const btnPlus   = card.querySelector('[data-qty-plus]');
          const addBtn    = card.querySelector('.addcart');
          const msgEl     = card.querySelector('[data-stock-msg]');

          const showMsg = (text)=>{
            if (!msgEl) return;
            msgEl.textContent = text;
            msgEl.classList.remove('d-none');
            clearTimeout(msgEl._t);
            msgEl._t = setTimeout(()=> msgEl.classList.add('d-none'), 1800);
          };

          const getAvailNow = ()=>{
            const currentInCart = parseInt(cartQtyEl?.textContent || '0', 10) || 0;
            return Math.max(0, stock - currentInCart);
          };

          const sanitizeQty = ()=>{
            if (!qtyField) return 1;
            qtyField.value = (qtyField.value || '').replace(/\D+/g,'') || '1';
            let v = parseInt(qtyField.value, 10);
            if (!isFinite(v) || v < 1) v = 1;
            return v;
          };

          const setUI = ()=>{
            const max = getAvailNow();
            let v = sanitizeQty();

            if (max > 0) v = Math.min(v, max);
            if (qtyField) qtyField.value = String(v);

            const disabledAll = (max <= 0);

            if (qtyField) qtyField.disabled = disabledAll;
            if (addBtn) addBtn.disabled = disabledAll;

            if (btnMinus) btnMinus.disabled = disabledAll || v <= 1;
            if (btnPlus)  btnPlus.disabled  = disabledAll || v >= max;
          };

          // expose updater for global refresh
          card._updateUI = setUI;

          btnMinus?.addEventListener('click', ()=>{
            const cur = sanitizeQty();
            if (qtyField) qtyField.value = String(Math.max(1, cur - 1));
            setUI();
          });

          btnPlus?.addEventListener('click', ()=>{
            const cur = sanitizeQty();
            if (qtyField) qtyField.value = String(cur + 1);
            setUI();
          });

          qtyField?.addEventListener('input', ()=>{
            sanitizeQty();
            setUI();
          });

          addBtn?.addEventListener('click', async ()=>{
            setUI();
            const max = getAvailNow();

            if (max <= 0){
              showMsg('Stock indisponible.');
              return;
            }

            const qty = Math.max(1, sanitizeQty());
            if (qty > max){
              showMsg(`Stock dispo: ${max}`);
              if (qtyField) qtyField.value = String(max);
              setUI();
              return;
            }

            const oldHtml = addBtn.innerHTML;
            addBtn.disabled = true;
            addBtn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>`;

            try{
              const res = await fetch('/api/cart/add', {
                method: 'POST',
                headers: { 'Content-Type':'application/json', 'Accept':'application/json' },
                body: JSON.stringify({ code, qty })
              });

              if (res.status === 401){
                showMsg('Connectez-vous pour ajouter au panier.');
              } else if (res.ok){
                // update local cart
                const freshCart = getCart();
                const current = parseInt(cartQtyEl?.textContent || '0', 10) || 0;
                const next = Math.min(current + qty, stock);

                setCartQtyInObj(freshCart, String(code), next);
                writeCart(freshCart, {emit:true, refreshHeader:true, eventName:'cart:changed'});

                if (cartQtyEl) cartQtyEl.textContent = String(next);
                if (qtyField) qtyField.value = '1';

                setUI();
                if (getAvailNow() <= 0) showMsg('Stock épuisé pour cet article.');
              } else {
                showMsg('Erreur ajout panier.');
              }
            } catch(e){
              showMsg('Erreur réseau.');
            } finally {
              addBtn.innerHTML = oldHtml;
              addBtn.disabled = (getAvailNow() <= 0);
              setUI();
            }
          });

          // init UI
          setUI();
          grid.appendChild(card);
        });

        // au cas où le cart a changé entre temps
        refreshGridCartBadges();
      }

      function fillSelect(selectEl, options, selectedValue){
        if (!selectEl) return;
        const keep0 = selectEl.options[0];
        selectEl.innerHTML = '';
        selectEl.appendChild(keep0);

        (options || []).forEach(v => {
          const opt = document.createElement('option');
          opt.value = v;
          opt.textContent = v;
          selectEl.appendChild(opt);
        });

        if (selectedValue) selectEl.value = selectedValue;
      }

      async function load(){
        if (apiError) apiError.classList.add('d-none');
        skeletons();
        if (statusLine) statusLine.textContent = 'Chargement…';

        try{
          const res = await fetch(buildUrl(), { headers: { 'Accept': 'application/json' } });
          const text = await res.text();

          const data = safeJsonParse(text, {});

          if (!res.ok || !data.ok){
            if (apiError){
              apiError.classList.remove('d-none');
              apiError.innerHTML = `<div class="fw-bold">Erreur API</div>
                <div class="small">Status: ${res.status}</div>
                <div class="small">Début: <code>${esc(text.slice(0, 280))}</code></div>`;
            }
            if (statusLine) statusLine.textContent = 'Erreur API';
            if (grid) grid.innerHTML = '';
            if (prevBtn) prevBtn.disabled = true;
            if (nextBtn) nextBtn.disabled = true;
            if (prevBtnBottom) prevBtnBottom.disabled = true;
            if (nextBtnBottom) nextBtnBottom.disabled = true;
            return;
          }

          // ✅ bornes années (min forcé à 1976 si l’API renvoie plus grand)
          const yMin = parseInt(data.yearMin, 10);
          const yMax = parseInt(data.yearMax, 10);

          if (isFinite(yMin) && isFinite(yMax) && yMin <= yMax){
            const first = !yearBoundsInitialized;
            yearBoundsInitialized = true;

            dataYearMin = Math.min(yMin, DEFAULT_YEAR_MIN);
            dataYearMax = yMax;
            if (dataYearMax < dataYearMin) dataYearMax = dataYearMin;

            updateYearSliderOptions();
            if (first) initYearFromQuery();
            else setYearValues(f_yearFrom?.value || dataYearMin, f_yearTo?.value || dataYearMax, true);
          } else {
            updateYearSliderOptions();
            setYearValues(f_yearFrom?.value || dataYearMin, f_yearTo?.value || dataYearMax, true);
          }

          // ✅ facets une seule fois
          if (!facetsLoaded && data.facets){
            facetsLoaded = true;
            fillSelect(f_family, data.facets.families || [], state.family);
            fillSelect(f_brand, data.facets.brands || [], state.brand);
            fillSelect(f_vehicle, data.facets.vehicles || [], state.vehicle);
          }

          const total = data.total || 0;
          const pages = data.pages || 1;

          if (pageLabel) pageLabel.textContent = `${state.page} / ${pages}`;
          if (prevBtn) prevBtn.disabled = state.page <= 1;
          if (nextBtn) nextBtn.disabled = state.page >= pages;

          if (pageLabelBottom) pageLabelBottom.textContent = `${state.page} / ${pages}`;
          if (prevBtnBottom) prevBtnBottom.disabled = state.page <= 1;
          if (nextBtnBottom) nextBtnBottom.disabled = state.page >= pages;

          if (statusLine) statusLine.textContent = `${total} article(s)`;

          const from = parseInt(f_yearFrom?.value || String(dataYearMin), 10);
          const to   = parseInt(f_yearTo?.value   || String(dataYearMax), 10);
          const isAll = (from === dataYearMin && to === dataYearMax);

          if (resultMeta){
            resultMeta.textContent = isAll
              ? `Année : toute la plage (${dataYearMin} → ${dataYearMax})`
              : `Année : ${from} → ${to}`;
          }

          render(data.items || [], data.imagesBaseUrl || '');
        } catch(e){
          if (apiError){
            apiError.classList.remove('d-none');
            apiError.innerHTML = `<div class="fw-bold">Erreur JS</div><div class="small">${esc(e.message || e)}</div>`;
          }
          if (statusLine) statusLine.textContent = 'Erreur JS';
          if (grid) grid.innerHTML = '';
        }
      }

      // ========= INIT =========
      ensureYearSlider();
      updateYearSliderOptions();
      initYearFromQuery();

      if (f_family) f_family.value = state.family;
      if (f_brand)  f_brand.value = state.brand;
      if (f_vehicle)f_vehicle.value = state.vehicle;

      applyBtn?.addEventListener('click', () => {
        state.page = 1;
        state.q = (f_q?.value || '').trim();
        state.family = (f_family?.value || '').trim();
        state.brand = (f_brand?.value || '').trim();
        state.vehicle = (f_vehicle?.value || '').trim();
        state.inStock = f_inStock?.checked ? '1' : '';
        syncUrlToBrowser();
        load();
      });

      clearBtn?.addEventListener('click', () => {
        state.page = 1;
        state.q = '';
        state.family = '';
        state.brand = '';
        state.vehicle = '';
        state.inStock = '';
        state.onlyNew = false;

        if (f_q) f_q.value = '';
        if (f_family) f_family.value = '';
        if (f_brand) f_brand.value = '';
        if (f_vehicle) f_vehicle.value = '';
        if (f_inStock) f_inStock.checked = false;

        setYearValues(dataYearMin, dataYearMax, true);

        syncUrlToBrowser();
        load();
      });

      prevBtn?.addEventListener('click', () => { if (state.page > 1){ state.page--; load(); } });
      nextBtn?.addEventListener('click', () => { state.page++; load(); });

      prevBtnBottom?.addEventListener('click', () => { if (state.page > 1){ state.page--; load(); } });
      nextBtnBottom?.addEventListener('click', () => { state.page++; load(); });

      let t = null;
      f_q?.addEventListener('input', () => {
        clearTimeout(t);
        t = setTimeout(() => {
          state.page = 1;
          state.q = (f_q.value || '').trim();
          syncUrlToBrowser();
          load();
        }, 350);
      });

      syncUrlToBrowser();

      // ✅ 1) sync server->local au chargement (utile si panier vidé ailleurs)
      syncCartFromServer({emit:true}).finally(() => {
        // ✅ 2) puis load articles
        load();
      });
    })();
  </script>
{% endblock %}