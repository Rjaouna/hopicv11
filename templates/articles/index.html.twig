{% extends 'base.html.twig' %}

{% block body %}

  {# ✅ ROBUSTE : si "initial" n'est pas passé par le controller, on le reconstitue depuis l’URL #}
  {% set initial = initial|default({
    q: app.request.query.get('q', ''),
    family: app.request.query.get('family', ''),
    brand: app.request.query.get('brand', app.request.query.get('marque', '')),
    vehicle: app.request.query.get('vehicle', app.request.query.get('vehicule', '')),
    anneeFrom: app.request.query.get('anneeFrom', ''),
    anneeTo: app.request.query.get('anneeTo', ''),
    annee: app.request.query.get('annee', ''),
    inStock: app.request.query.get('inStock', ''),
    new: app.request.query.get('new', ''),
    newDays: (app.request.query.get('newDays', 5))
  }) %}

  <style>
    :root{
      --pc-radius: 18px;
      --pc-border: rgba(0,0,0,.10);
      --pc-shadow: 0 14px 34px rgba(0,0,0,.08);
      --pc-muted: rgba(0,0,0,.58);
    }
    body.theme-dark{
      --pc-border: rgba(255,255,255,.14);
      --pc-shadow: 0 18px 46px rgba(0,0,0,.35);
      --pc-muted: rgba(255,255,255,.65);
    }

    .page-hero{
      border-radius: 22px;
      border: 1px solid var(--pc-border);
      box-shadow: var(--pc-shadow);
      padding: 16px;
      background:
        radial-gradient(900px circle at 10% 10%, rgba(13,110,253,.16), transparent 40%),
        radial-gradient(900px circle at 90% 30%, rgba(25,135,84,.14), transparent 38%),
        linear-gradient(180deg, rgba(0,0,0,.02), transparent);
    }

    .filters-card{
      border-radius: 22px;
      border: 1px solid var(--pc-border);
      box-shadow: var(--pc-shadow);
      background: rgba(255,255,255,.75);
      backdrop-filter: blur(8px);
    }
    body.theme-dark .filters-card{ background: rgba(18,18,22,.62); }

    .product-grid{
      display:grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 14px;
    }
    @media (min-width: 768px){
      .product-grid{ grid-template-columns: repeat(3, minmax(0,1fr)); }
    }
    @media (min-width: 1200px){
      .product-grid{ grid-template-columns: repeat(4, minmax(0,1fr)); }
    }

    .product-card{
      position: relative;
      border-radius: var(--pc-radius);
      border: 1px solid var(--pc-border);
      box-shadow: 0 10px 24px rgba(0,0,0,.06);
      background: rgba(255,255,255,.85);
      overflow: hidden;
      transition: transform .08s ease, box-shadow .12s ease, border-color .12s ease;
    }
    body.theme-dark .product-card{ background: rgba(18,18,22,.70); }

    .product-card:hover{
      transform: translateY(-2px);
      box-shadow: 0 16px 32px rgba(0,0,0,.10);
      border-color: rgba(13,110,253,.22);
    }

    .wishlist-button{
      position:absolute;
      top:10px; right:10px;
      width: 40px; height: 40px;
      border-radius: 14px;
      border: 1px solid var(--pc-border);
      background: rgba(255,255,255,.82);
      display:grid; place-items:center;
      z-index: 5;
    }
    body.theme-dark .wishlist-button{ background: rgba(18,18,22,.72); }

    .product-card__image{
      position: relative;
      padding: 14px;
      background: linear-gradient(180deg, rgba(0,0,0,.02), transparent);
    }

    .badge-pill{
      position:absolute;
      left: 12px;
      top: 12px;
      display:flex; align-items:center; gap:6px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.80);
      font-weight: 900;
      font-size: .78rem;
      z-index: 4;
    }
    body.theme-dark .badge-pill{
      border-color: rgba(255,255,255,.14);
      background: rgba(18,18,22,.70);
    }

    .badge-new{
      right: 12px;
      left: auto;
      background: rgba(25,135,84,.16);
      border-color: rgba(25,135,84,.25);
      color: rgba(25,135,84,.95);
    }

    .product-img{
      width: 100%;
      aspect-ratio: 1/1;
      object-fit: contain;
      border-radius: 16px;
      background: rgba(255,255,255,.35);
      padding: 12px;
      border: 1px solid rgba(0,0,0,.06);
    }
    body.theme-dark .product-img{ background: rgba(255,255,255,.03); border-color: rgba(255,255,255,.10); }

    .product-card__info{ padding: 12px 14px 0 14px; }

    .refPlusCopy{
      display:flex; align-items:center; gap:8px;
      font-weight: 900;
      font-size: .95rem;
    }
    .product-reference{ text-decoration:none; color: inherit; }

    .designation{
      display:block;
      margin-top: 6px;
      font-weight: 800;
      font-size: .92rem;
      color: rgba(0,0,0,.75);
      text-decoration:none;
    }
    body.theme-dark .designation{ color: rgba(255,255,255,.86); }

    .meta-line{
      margin-top: 8px;
      font-size: .80rem;
      color: var(--pc-muted);
      display:flex;
      flex-wrap:wrap;
      gap: 8px;
    }
    .meta-chip{
      border: 1px solid rgba(0,0,0,.10);
      background: rgba(255,255,255,.7);
      border-radius: 999px;
      padding: 4px 8px;
      font-weight: 800;
    }
    body.theme-dark .meta-chip{
      border-color: rgba(255,255,255,.14);
      background: rgba(18,18,22,.62);
    }

    .product-card__footer{ padding: 12px 14px 14px 14px; }

    .product-card__prices{
      display:flex;
      align-items:baseline;
      gap: 8px;
      font-weight: 950;
    }
    .price-ttc{ font-size: 1.05rem; }
    .price-label{ font-size: .78rem; color: var(--pc-muted); font-weight: 900; }

    .bottomFooterWrapper{
      margin-top: 10px;
      display:flex;
      align-items:center;
      gap: 10px;
    }

    .qty-input{
      width: 84px;
      border-radius: 14px !important;
      font-weight: 900;
    }

    .addcart{
      margin-left:auto;
      width: 44px; height: 44px;
      border-radius: 16px;
      display:grid; place-items:center;
      border: 1px solid rgba(13,110,253,.25);
      background: rgba(13,110,253,.10);
    }
    .addcart:hover{ background: rgba(13,110,253,.16); }

    .skeleton{
      height: 380px;
      border-radius: var(--pc-radius);
      border: 1px solid rgba(0,0,0,.06);
      background: linear-gradient(90deg, rgba(0,0,0,.04), rgba(0,0,0,.08), rgba(0,0,0,.04));
      background-size: 200% 100%;
      animation: sk 1.2s infinite;
    }
    @keyframes sk { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* ✅ (FIX) année : DEUX curseurs visibles (roulette) */
    .range-wrap{
      position: relative;
      height: 30px;
      margin-top: 6px;
    }
    .range-wrap .form-range{
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 30px;
      margin: 0;
      background: transparent;
    }
    /* on met le track transparent pour laisser voir la barre bootstrap dessous */
    .range-wrap .form-range::-webkit-slider-runnable-track{ background: transparent; }
    .range-wrap .form-range::-moz-range-track{ background: transparent; }
    /* ordre des 2 curseurs (les 2 restent cliquables) */
    #f_yearFrom{ z-index: 3; }
    #f_yearTo{ z-index: 2; }
  </style>

  <div class="container py-4"
       data-initial='{{ initial|json_encode(constant("JSON_UNESCAPED_UNICODE"))|e("html_attr") }}'>

    <div class="page-hero mb-3 d-flex align-items-start justify-content-between flex-wrap gap-2">
      <div>
        <h3 class="mb-1">Articles</h3>
        <div class="text-muted small">
          Recherche instantanée + filtres.
          {% if initial.new == '1' %}
            <span class="badge text-bg-success ms-2">Nouveautés ({{ initial.newDays }}j)</span>
          {% endif %}
        </div>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" href="{{ path('articles_page') }}">Reset</a>
        <a class="btn btn-outline-primary" href="{{ path('articles_page', { new: 1, newDays: 5 }) }}">
          Nouveautés (5j)
        </a>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-3">
        <div class="filters-card p-3">
          <div class="fw-bold mb-2">Filtres</div>

          <div class="mb-2">
            <label class="form-label small mb-1">Recherche</label>
            <input class="form-control form-control-sm" id="f_q" placeholder="Mot-clé / référence...">
          </div>

          {# ✅ dropdown Famille #}
          <div class="mb-2">
            <label class="form-label small mb-1">Famille</label>
            <select class="form-select form-select-sm" id="f_family">
              <option value="">Toutes</option>
            </select>
          </div>

          {# ✅ dropdown Marque #}
          <div class="mb-2">
            <label class="form-label small mb-1">Marque</label>
            <select class="form-select form-select-sm" id="f_brand">
              <option value="">Toutes</option>
            </select>
          </div>

          {# ✅ dropdown Véhicule #}
          <div class="mb-2">
            <label class="form-label small mb-1">Véhicule</label>
            <select class="form-select form-select-sm" id="f_vehicle">
              <option value="">Tous</option>
            </select>
          </div>

          {# ✅ Année : plage min/max avec “roulette” visible #}
          <div class="mb-2">
            <label class="form-label small mb-1 d-flex align-items-center justify-content-between">
              <span>Année</span>
              <span class="badge text-bg-secondary" id="anneeBadge">—</span>
            </label>

            <div class="range-wrap">
              <input class="form-range" type="range" id="f_yearFrom" min="2000" max="2030" step="1" value="2000">
              <input class="form-range" type="range" id="f_yearTo"   min="2000" max="2030" step="1" value="2030">
            </div>

            <div class="progress" style="height:10px; border-radius:999px;">
              <div class="progress-bar" id="yearRangeBar" role="progressbar" style="width:100%"></div>
            </div>

            <div class="d-flex justify-content-between small text-muted mt-1">
              <span id="yearMinLabel">—</span>
              <span id="yearMaxLabel">—</span>
            </div>
          </div>

          <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" id="f_inStock">
            <label class="form-check-label small" for="f_inStock">En stock uniquement</label>
          </div>

          <div class="mt-3 d-grid gap-2">
            <button class="btn btn-primary btn-sm" id="applyFilters">Appliquer</button>
            <button class="btn btn-outline-secondary btn-sm" id="clearFilters">Effacer</button>
          </div>

          <div class="small text-muted mt-3" id="resultMeta">—</div>
        </div>
      </div>

      <div class="col-lg-9">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
          <div class="small text-muted" id="statusLine">—</div>
          <div class="d-flex gap-2 align-items-center">
            <button class="btn btn-outline-secondary btn-sm" id="prevBtn" disabled>←</button>
            <span class="small" id="pageLabel">1</span>
            <button class="btn btn-outline-secondary btn-sm" id="nextBtn" disabled>→</button>
          </div>
        </div>

        <div id="grid" class="product-grid"></div>
        <div class="alert alert-danger mt-3 d-none" id="apiError"></div>
      </div>
    </div>
  </div>

  <script>
    (function(){
      const wrap = document.querySelector('[data-initial]');
      const initial = JSON.parse(wrap.getAttribute('data-initial') || '{}');

      const f_q = document.getElementById('f_q');
      const f_family = document.getElementById('f_family');
      const f_brand = document.getElementById('f_brand');
      const f_vehicle = document.getElementById('f_vehicle');

      const f_yearFrom = document.getElementById('f_yearFrom');
      const f_yearTo = document.getElementById('f_yearTo');
      const anneeBadge = document.getElementById('anneeBadge');
      const yearRangeBar = document.getElementById('yearRangeBar');
      const yearMinLabel = document.getElementById('yearMinLabel');
      const yearMaxLabel = document.getElementById('yearMaxLabel');

      const f_inStock = document.getElementById('f_inStock');

      const applyBtn = document.getElementById('applyFilters');
      const clearBtn = document.getElementById('clearFilters');
      const grid = document.getElementById('grid');

      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const pageLabel = document.getElementById('pageLabel');
      const statusLine = document.getElementById('statusLine');
      const resultMeta = document.getElementById('resultMeta');
      const apiError = document.getElementById('apiError');

      // bornes dynamiques (par défaut, seront remplacées dès que l’API renvoie anneeMin/anneeMax)
      let dataYearMin = 2000;
      let dataYearMax = 2030;

      let state = {
        page: 1,
        limit: 24,
        q: initial.q || '',
        family: initial.family || '',
        brand: initial.brand || '',
        vehicle: initial.vehicle || '',
        inStock: initial.inStock || '',
        onlyNew: (initial.new === '1'),
        newDays: initial.newDays || 5,

        // plage année
        yearFrom: initial.anneeFrom || '',
        yearTo: initial.anneeTo || '',
        // compat: si avant tu passais ?annee=2022
        yearSingle: initial.annee || ''
      };

      f_q.value = state.q;
      f_inStock.checked = (state.inStock === '1');

      function esc(s){
        return String(s ?? '').replace(/[&<>"']/g, m => ({
          '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
        }[m]));
      }

      function money(v){
        const n = Number(String(v).replace(',', '.'));
        if (!isFinite(n)) return esc(v);
        return n.toFixed(2);
      }

      function truncate(s, max){
        s = String(s ?? '').trim();
        return (s.length <= max) ? s : (s.slice(0, max) + '…');
      }

      function getWishlist(){ try { return JSON.parse(localStorage.getItem('wishlist') || '[]'); } catch { return []; } }
      function setWishlist(arr){
        localStorage.setItem('wishlist', JSON.stringify(arr));
        if (window.refreshHeaderCounts) window.refreshHeaderCounts();
      }
      function getCart(){ try { return JSON.parse(localStorage.getItem('cart') || '{}'); } catch { return {}; } }
      function setCart(obj){
        localStorage.setItem('cart', JSON.stringify(obj));
        if (window.refreshHeaderCounts) window.refreshHeaderCounts();
      }

      function skeletons(){
        grid.innerHTML = '';
        for (let i=0; i<8; i++){
          const d = document.createElement('div');
          d.className = 'skeleton';
          grid.appendChild(d);
        }
      }

      function clampYearSliders(){
        f_yearFrom.min = String(dataYearMin);
        f_yearFrom.max = String(dataYearMax);
        f_yearTo.min   = String(dataYearMin);
        f_yearTo.max   = String(dataYearMax);

        let from = parseInt(f_yearFrom.value || String(dataYearMin), 10);
        let to   = parseInt(f_yearTo.value   || String(dataYearMax), 10);

        from = Math.max(dataYearMin, Math.min(dataYearMax, from));
        to   = Math.max(dataYearMin, Math.min(dataYearMax, to));

        if (from > to) { const tmp = from; from = to; to = tmp; }

        f_yearFrom.value = String(from);
        f_yearTo.value   = String(to);

        yearMinLabel.textContent = String(dataYearMin);
        yearMaxLabel.textContent = String(dataYearMax);

        if (from === dataYearMin && to === dataYearMax){
          anneeBadge.textContent = 'Tout';
        } else if (from === to){
          anneeBadge.textContent = String(from);
        } else {
          anneeBadge.textContent = `${from} → ${to}`;
        }

        const range = (dataYearMax - dataYearMin) || 1;
        const leftPct = ((from - dataYearMin) / range) * 100;
        const rightPct = ((to - dataYearMin) / range) * 100;
        yearRangeBar.style.marginLeft = leftPct + '%';
        yearRangeBar.style.width = Math.max(0, rightPct - leftPct) + '%';
      }

      function initYearFromQuery(){
        let from = state.yearFrom ? parseInt(state.yearFrom, 10) : NaN;
        let to   = state.yearTo   ? parseInt(state.yearTo, 10)   : NaN;

        if ((!isFinite(from) || !isFinite(to)) && state.yearSingle){
          const y = parseInt(state.yearSingle, 10);
          if (isFinite(y)){ from = y; to = y; }
        }

        if (!isFinite(from)) from = dataYearMin;
        if (!isFinite(to))   to = dataYearMax;

        f_yearFrom.value = String(from);
        f_yearTo.value   = String(to);
        clampYearSliders();
      }

      function buildUrl(){
        const url = new URL('/api/articles', window.location.origin);
        url.searchParams.set('page', String(state.page));
        url.searchParams.set('limit', String(state.limit));

        if (state.q) url.searchParams.set('q', state.q);
        if (state.family) url.searchParams.set('family', state.family);
        if (state.brand) url.searchParams.set('brand', state.brand);
        if (state.vehicle) url.searchParams.set('vehicle', state.vehicle);
        if (state.inStock === '1') url.searchParams.set('inStock', '1');

        const from = parseInt(f_yearFrom.value || String(dataYearMin), 10);
        const to   = parseInt(f_yearTo.value   || String(dataYearMax), 10);
        const isAll = (from === dataYearMin && to === dataYearMax);

        if (!isAll){
          url.searchParams.set('anneeFrom', String(from));
          url.searchParams.set('anneeTo', String(to));
        }

        if (state.onlyNew) {
          url.searchParams.set('new', '1');
          url.searchParams.set('newDays', String(state.newDays));
        }

        return url.toString();
      }

      function syncUrlToBrowser(){
        const url = new URL('{{ path("articles_page") }}', window.location.origin);

        if (state.q) url.searchParams.set('q', state.q);
        if (state.family) url.searchParams.set('family', state.family);
        if (state.brand) url.searchParams.set('brand', state.brand);
        if (state.vehicle) url.searchParams.set('vehicle', state.vehicle);
        if (state.inStock === '1') url.searchParams.set('inStock', '1');

        const from = parseInt(f_yearFrom.value || String(dataYearMin), 10);
        const to   = parseInt(f_yearTo.value   || String(dataYearMax), 10);
        const isAll = (from === dataYearMin && to === dataYearMax);

        if (!isAll){
          url.searchParams.set('anneeFrom', String(from));
          url.searchParams.set('anneeTo', String(to));
        }

        if (state.onlyNew) {
          url.searchParams.set('new', '1');
          url.searchParams.set('newDays', String(state.newDays));
        }

        history.replaceState({}, '', url.toString());
      }

      // ✅ placeholder inline (stable card)
      const FALLBACK_IMG =
        "data:image/svg+xml;charset=utf-8," +
        encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' width='600' height='600'>
          <rect width='100%' height='100%' fill='#f3f4f6'/>
          <text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle'
                font-family='Arial' font-size='28' fill='#6b7280'>No Image</text>
        </svg>`);

      function render(items, imagesBaseUrl){
        const wishlist = new Set(getWishlist());
        grid.innerHTML = '';

        if (!items.length){
          grid.innerHTML = `<div class="text-muted small">Aucun article trouvé.</div>`;
          return;
        }

        items.forEach(a => {
          const uid = a.UniqueId;
          const code = a.Id;
          const desFull = a.DesComClear || '';
          const des = truncate(desFull, 15);

          const base = (imagesBaseUrl || '').replace(/\/$/, '');
          const img = (base && uid) ? (base + '/' + uid + '.png') : FALLBACK_IMG;

          const stock = Number(a.RealStock || 0);
          const isNew = !!a.isNew;

          const card = document.createElement('div');
          card.className = 'product-card';

          card.innerHTML = `
            <button class="wishlist-button" type="button" title="Favoris">
              <i class="${wishlist.has(code) ? 'fa-solid' : 'fa-regular'} fa-heart"></i>
            </button>

            <div class="product-card__image">
              <div class="badge-pill" title="Stock">
                <i class="fa fa-shopping-basket"></i>
                <span>${stock}</span>
              </div>

              ${isNew ? `<div class="badge-pill badge-new" title="Nouveauté"><i class="fa-solid fa-bolt"></i> NOUVEAUTÉ</div>` : ''}

              <img class="product-img" src="${esc(img)}" alt="${esc(code)}"
                   onerror="this.onerror=null;this.src='${FALLBACK_IMG}'">
            </div>

            <div class="product-card__info">
              <div class="refPlusCopy">
                <a href="javascript:void(0)" class="product-reference">${esc(code)}</a>
                <span class="copy-icon" title="Copier" style="cursor:pointer">
                  <i class="fa-solid fa-copy"></i>
                </span>
              </div>

              <a href="javascript:void(0)" class="designation" title="${esc(desFull)}">${esc(des)}</a>

              <div class="meta-line">
                ${a.xx_Marque ? `<span class="meta-chip">${esc(a.xx_Marque)}</span>` : ''}
                ${a.FamilyName ? `<span class="meta-chip">${esc(a.FamilyName)}</span>` : ''}
              </div>
            </div>

            <div class="product-card__footer">
              <div class="product-card__prices">
                <span class="price-ttc">${money(a.SalePriceVatIncluded)} DH</span>
                <span class="price-label">[TTC]</span>
              </div>

              <div class="bottomFooterWrapper">
                <input class="form-control form-control-sm qty-input" type="number" min="1" value="1">
                <button class="addcart" type="button" title="Ajouter au panier">
                  <i class="fa-solid fa-cart-plus"></i>
                </button>
              </div>
            </div>
          `;

          card.querySelector('.wishlist-button').addEventListener('click', () => {
            const arr = getWishlist();
            const i = arr.indexOf(code);
            if (i >= 0) arr.splice(i, 1); else arr.push(code);
            setWishlist(arr);
            card.querySelector('.wishlist-button i').className =
              (arr.includes(code) ? 'fa-solid' : 'fa-regular') + ' fa-heart';
          });

          card.querySelector('.copy-icon').addEventListener('click', async () => {
            try { await navigator.clipboard.writeText(code); } catch {}
          });

          const qtyInput = card.querySelector('.qty-input');
          card.querySelector('.addcart').addEventListener('click', () => {
            const qty = Math.max(1, parseInt(qtyInput.value || '1', 10));
            const cart = getCart();
            cart[code] = (parseInt(cart[code] || '0', 10) || 0) + qty;
            setCart(cart);
          });

          grid.appendChild(card);
        });
      }

      async function load(){
        apiError.classList.add('d-none');
        skeletons();
        statusLine.textContent = 'Chargement…';

        try{
          const res = await fetch(buildUrl(), { headers: { 'Accept': 'application/json' } });
          const text = await res.text();
          let data = {};
          try { data = JSON.parse(text); } catch { data = {}; }

          if (!res.ok || !data.ok){
            apiError.classList.remove('d-none');
            apiError.innerHTML = `<div class="fw-bold">Erreur API</div>
              <div class="small">Status: ${res.status}</div>
              <div class="small">Début: <code>${esc(text.slice(0, 280))}</code></div>`;
            statusLine.textContent = 'Erreur API';
            grid.innerHTML = '';
            prevBtn.disabled = true;
            nextBtn.disabled = true;
            return;
          }

          const minFromApi = data.anneeMin ?? data.yearsMin ?? null;
          const maxFromApi = data.anneeMax ?? data.yearsMax ?? null;
          if (minFromApi !== null && maxFromApi !== null){
            const mn = parseInt(minFromApi, 10);
            const mx = parseInt(maxFromApi, 10);
            if (isFinite(mn) && isFinite(mx) && mn <= mx){
              const firstInit = (dataYearMin === 2000 && dataYearMax === 2030);
              dataYearMin = mn;
              dataYearMax = mx;
              if (firstInit) initYearFromQuery();
              else clampYearSliders();
            }
          } else {
            clampYearSliders();
          }

          const total = data.total || 0;
          const pages = data.pages || 1;

          pageLabel.textContent = `${state.page} / ${pages}`;
          prevBtn.disabled = state.page <= 1;
          nextBtn.disabled = state.page >= pages;

          statusLine.textContent = `${total} article(s)`;

          const from = parseInt(f_yearFrom.value || String(dataYearMin), 10);
          const to   = parseInt(f_yearTo.value   || String(dataYearMax), 10);
          const isAll = (from === dataYearMin && to === dataYearMax);

          resultMeta.textContent = isAll
            ? `Année : toute la plage (${dataYearMin} → ${dataYearMax})`
            : `Année : ${from} → ${to}`;

          render(data.items || [], data.imagesBaseUrl || '');
        } catch(e){
          apiError.classList.remove('d-none');
          apiError.innerHTML = `<div class="fw-bold">Erreur JS</div><div class="small">${esc(e.message || e)}</div>`;
          statusLine.textContent = 'Erreur JS';
          grid.innerHTML = '';
        }
      }

      async function loadSelectOptions(){
        async function fill(select, endpoint, selected){
          select.innerHTML = `<option value="">Chargement...</option>`;
          try{
            const res = await fetch(endpoint, { headers: { 'Accept':'application/json' }});
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.message || 'Erreur API');

            select.innerHTML = `<option value="">Tous</option>`;
            (data.items || []).forEach(it => {
              const opt = document.createElement('option');
              opt.value = it.value;
              opt.textContent = it.value;
              select.appendChild(opt);
            });

            if (selected) select.value = selected;
          } catch(e){
            select.innerHTML = `<option value="">Tous</option>`;
          }
        }

        await fill(f_family, '/api/catalog/families', state.family);
        await fill(f_brand,  '/api/catalog/brands',  state.brand);
        await fill(f_vehicle,'/api/catalog/vehicles',state.vehicle);
      }

      function onYearInput(){
        let from = parseInt(f_yearFrom.value || String(dataYearMin), 10);
        let to   = parseInt(f_yearTo.value   || String(dataYearMax), 10);

        if (from > to){
          const active = document.activeElement;
          if (active === f_yearFrom) f_yearTo.value = String(from);
          else f_yearFrom.value = String(to);
        }
        clampYearSliders();
      }
      f_yearFrom.addEventListener('input', onYearInput);
      f_yearTo.addEventListener('input', onYearInput);

      f_yearFrom.value = String(dataYearMin);
      f_yearTo.value   = String(dataYearMax);
      clampYearSliders();

      loadSelectOptions().then(() => {
        f_family.value = state.family;
        f_brand.value = state.brand;
        f_vehicle.value = state.vehicle;
      });

      applyBtn.addEventListener('click', () => {
        state.page = 1;
        state.q = f_q.value.trim();
        state.family = (f_family.value || '').trim();
        state.brand = (f_brand.value || '').trim();
        state.vehicle = (f_vehicle.value || '').trim();
        state.inStock = f_inStock.checked ? '1' : '';
        syncUrlToBrowser();
        load();
      });

      clearBtn.addEventListener('click', () => {
        state.page = 1;
        state.q = '';
        state.family = '';
        state.brand = '';
        state.vehicle = '';
        state.inStock = '';
        state.onlyNew = false;

        f_q.value = '';
        f_family.value = '';
        f_brand.value = '';
        f_vehicle.value = '';
        f_inStock.checked = false;

        f_yearFrom.value = String(dataYearMin);
        f_yearTo.value   = String(dataYearMax);
        clampYearSliders();

        syncUrlToBrowser();
        load();
      });

      prevBtn.addEventListener('click', () => { if (state.page > 1){ state.page--; load(); } });
      nextBtn.addEventListener('click', () => { state.page++; load(); });

      let t = null;
      f_q.addEventListener('input', () => {
        clearTimeout(t);
        t = setTimeout(() => {
          state.page = 1;
          state.q = f_q.value.trim();
          syncUrlToBrowser();
          load();
        }, 350);
      });

      syncUrlToBrowser();
      load();
    })();
  </script>
{% endblock %}