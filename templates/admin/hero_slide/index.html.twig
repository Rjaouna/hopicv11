{% extends 'base.html.twig' %}
{% block title %}Hero Slides{% endblock %}

{% block body %}
<div class="container px-3 px-lg-4 my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Slides (Hero)</h1>
    <a href="{{ path('admin_hero_slide_new') }}" class="btn btn-primary rounded-pill">
      <i class="fa-solid fa-plus me-2"></i>Ajouter
    </a>
  </div>

  <div class="row g-3">
    {% for s in slides %}
      <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm" style="border-radius:18px; overflow:hidden;">
          <img src="{{ asset('img/slides/' ~ s.image) }}" alt="" style="width:100%; height:220px; object-fit:cover;">
          <div class="card-body">
            <div class="fw-bold">{{ s.title ?: '—' }}</div>
            <div class="text-muted small">{{ s.subtitle ?: '' }}</div>

            <div class="d-flex gap-2 mt-3">
              <a href="{{ path('admin_hero_slide_edit', {id: s.id}) }}" class="btn btn-outline-secondary btn-sm rounded-pill">
                <i class="fa-solid fa-pen"></i>
              </a>

              <form method="post" action="{{ path('admin_hero_slide_delete', {id:s.id}) }}"
                    onsubmit="return confirm('Supprimer ce slide ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_slide_' ~ s.id) }}">
                <button class="btn btn-outline-danger btn-sm rounded-pill" type="submit">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </form>

              <form method="post" action="{{ path('admin_hero_slide_bump', {id:s.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('bump_slide_' ~ s.id) }}">
                <button class="btn btn-outline-primary btn-sm rounded-pill" type="submit" title="Mettre en avant">
                  <i class="fa-solid fa-star"></i>
                </button>
              </form>

              <span class="ms-auto small text-muted">
                {{ (s.pinnedAt ?: s.createdAt)|date('d/m/Y H:i') }}
              </span>
            </div>
          </div>
        </div>
      </div>
    {% else %}
      <div class="col-12">
        <div class="alert alert-light border">Aucun slide.</div>
      </div>
    {% endfor %}
  </div>
</div>
{% endblock %}