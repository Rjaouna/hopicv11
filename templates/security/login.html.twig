{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<style>
  .login-wrap{
    min-height: calc(100vh - 160px);
    display:flex;
    align-items:center;
    justify-content:center;
    padding: 24px 0;
  }
  .login-card{
    width: min(520px, 94vw); /* ✅ plus large */
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.08);
    box-shadow: 0 16px 44px rgba(0,0,0,.08);
    overflow:hidden;
    background: rgba(255,255,255,.92);
  }
  body.theme-dark .login-card{
    border-color: rgba(255,255,255,.14);
    background: rgba(18,18,22,.72);
    box-shadow: 0 18px 60px rgba(0,0,0,.55);
    color: rgba(255,255,255,.88);
  }

  .login-head{
    padding: 18px 18px 14px 18px;
    border-bottom: 1px solid rgba(0,0,0,.06);
    background:
      radial-gradient(800px circle at 10% 10%, rgba(13,110,253,.16), transparent 45%),
      radial-gradient(800px circle at 90% 30%, rgba(25,135,84,.14), transparent 45%),
      linear-gradient(180deg, rgba(0,0,0,.02), transparent);
  }
  body.theme-dark .login-head{
    border-bottom-color: rgba(255,255,255,.10);
    background:
      radial-gradient(800px circle at 10% 10%, rgba(13,110,253,.18), transparent 45%),
      radial-gradient(800px circle at 90% 30%, rgba(25,135,84,.18), transparent 45%),
      linear-gradient(180deg, rgba(255,255,255,.03), transparent);
  }

  .login-body{ padding: 18px; }

  .login-control{
    height: 52px;            /* ✅ champs plus hauts/larges */
    border-radius: 14px;
    font-weight: 700;
  }
  .login-btn{
    height: 52px;
    border-radius: 14px;
    font-weight: 900;
  }

  .login-muted{
    color: rgba(0,0,0,.55);
    font-weight: 700;
  }
  body.theme-dark .login-muted{ color: rgba(255,255,255,.65); }
</style>

<div class="container login-wrap">
  <div class="login-card">

    <div class="login-head">
      <div class="d-flex align-items-center gap-2">
        <div class="rounded-4 d-grid place-items-center"
             style="width:44px;height:44px;background:rgba(13,110,253,.12);border:1px solid rgba(13,110,253,.22);">
          <i class="fa-solid fa-lock"></i>
        </div>
        <div>
          <div class="fw-bold fs-5">Connexion</div>
          <div class="small login-muted">Accédez à votre espace</div>
        </div>
      </div>
    </div>

    <div class="login-body">
      <form method="post" novalidate>
        {% if error %}
          <div class="alert alert-danger mb-3">
            {{ error.messageKey|trans(error.messageData, 'security') }}
          </div>
        {% endif %}

        {% if app.user %}
          <div class="alert alert-info mb-3">
            Vous êtes déjà connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
            <a href="{{ logout_path() }}" class="ms-1">Déconnexion</a>
          </div>
        {% endif %}

        <div class="mb-3">
          <label for="inputEmail" class="form-label fw-bold">Email</label>
          <input
            type="email"
            value="{{ last_username }}"
            name="email"
            id="inputEmail"
            class="form-control login-control"
            placeholder="ex: contact@hopic.ma"
            autocomplete="email"
            required
            autofocus
          >
        </div>

        <div class="mb-2">
          <label for="inputPassword" class="form-label fw-bold">Mot de passe</label>
          <input
            type="password"
            name="password"
            id="inputPassword"
            class="form-control login-control"
            placeholder="Votre mot de passe"
            autocomplete="current-password"
            required
          >
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="d-grid mt-3">
          <button class="btn btn-primary login-btn" type="submit">
            Se connecter
          </button>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
          <span class="small login-muted">Besoin d’aide ?</span>
          <a class="small fw-bold text-decoration-none" href="#">
            Mot de passe oublié
          </a>
        </div>
      </form>
    </div>

  </div>
</div>
{% endblock %}