{# templates/partials/_header.html.twig #}
<style>

  :root{
    --hd-radius: 18px;
    --hd-border: rgba(0,0,0,.08);
    --hd-shadow: 0 14px 34px rgba(0,0,0,.08);
    --hd-glass: rgba(255,255,255,1);
    --hd-glass2: rgba(255,255,255,.62);
    --hd-text: rgba(0,0,0,.78);
    --hd-muted: rgba(0,0,0,.56);
  }

  body.theme-dark{
    --hd-border: rgba(255,255,255,.14);
    --hd-shadow: 0 16px 44px rgba(0,0,0,.35);
    --hd-glass: rgba(18,18,22,.72);
    --hd-glass2: rgba(18,18,22,.55);
    --hd-text: rgba(255,255,255,.86);
    --hd-muted: rgba(255,255,255,.62);
    background: #0f1115;
    color: rgba(255,255,255,.86);
  }

  .site__header{ position: sticky; top: 0; z-index: 1025; }

  .header-wrap{
    border-bottom: 1px solid var(--hd-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    background: var(--hd-glass);
  }

  .header-topbar{
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--hd-border);
    background:
      radial-gradient(800px circle at 10% 20%, rgba(13,110,253,.16), transparent 40%),
      radial-gradient(900px circle at 90% 40%, rgba(25,135,84,.14), transparent 38%),
      linear-gradient(180deg, rgba(0,0,0,.02), transparent);
  }
  body.theme-dark .header-topbar{
    background:
      radial-gradient(800px circle at 10% 20%, rgba(13,110,253,.18), transparent 40%),
      radial-gradient(900px circle at 90% 40%, rgba(25,135,84,.18), transparent 38%),
      linear-gradient(180deg, rgba(255,255,255,.03), transparent);
  }

  .topbar-row{ display:flex; align-items:center; gap:12px; padding: 10px 0; color: var(--hd-text); }
  .topbar-welcome{
    font-weight: 700; color: var(--hd-text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 520px;
  }
  .topbar-welcome .account-name{ font-weight: 900; color: var(--hd-text); }

  .topbar-phone{
    margin-left: 8px;
    text-decoration:none;
    display:flex; align-items:center; gap:10px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--hd-glass2);
    color: var(--hd-text);
    font-weight: 800;
  }
  .topbar-phone:hover{ filter: brightness(.98); }
  .topbar-spacer{ flex:1; }

  .hd-iconbtn{
    width: 40px; height: 40px;
    border-radius: 14px;
    border: 1px solid var(--hd-border);
    background: var(--hd-glass2);
    display:grid; place-items:center;
    color: var(--hd-text);
    text-decoration:none;
    transition: transform .08s ease, filter .12s ease;
  }
  .hd-iconbtn:hover{ transform: translateY(-1px); filter: brightness(.98); }

  .hd-badge{
    position:absolute;
    top:-6px; right:-6px;
    border-radius:999px;
    padding: 3px 5px;
    font-size:.72rem;
    border: 1px solid rgba(0,0,0,.10);
  }
  body.theme-dark .hd-badge{ border-color: rgba(255,255,255,.15); }

  .hd-dropdown .dropdown-menu{
    border-radius: 18px;
    box-shadow: var(--hd-shadow);
    border: 1px solid var(--hd-border);
    overflow: hidden;
    min-width: 320px;
    background: var(--hd-glass);
    color: var(--hd-text);
  }

  .notif-head{
    padding: 12px 14px;
    border-bottom: 1px solid var(--hd-border);
    display:flex; align-items:center; justify-content:space-between;
    gap: 10px;
  }
  .notif-head h6{ margin:0; font-weight: 900; }
  .notif-head button{ border:none; background: transparent; font-weight: 800; color: #0d6efd; }
  body.theme-dark .notif-head button{ color: #7fb0ff; }

  .notif-item{
    display:flex; gap:10px;
    padding: 12px 14px;
    text-decoration:none;
    color: var(--hd-text);
    border-bottom: 1px solid rgba(0,0,0,.05);
  }
  body.theme-dark .notif-item{ border-bottom-color: rgba(255,255,255,.08); }
  .notif-item:hover{ background: rgba(13,110,253,.06); }
  .notif-dot{
    width: 10px; height: 10px;
    border-radius: 999px;
    margin-top: 6px;
    background: rgba(220,53,69,.95);
    box-shadow: 0 0 0 4px rgba(220,53,69,.12);
    flex: 0 0 auto;
  }
  .notif-content p{ margin:0; font-size:.92rem; line-height:1.2; }
  .notif-time{ margin-top:6px; font-size:.78rem; color: var(--hd-muted); display:block; }

  .settings-btn{
    border-radius: 999px !important;
    border: 1px solid var(--hd-border) !important;
    background: var(--hd-glass2) !important;
    color: var(--hd-text) !important;
    font-weight: 900 !important;
    padding: 8px 12px !important;
  }



  .brand-box{ display:flex; align-items:center; gap:10px; text-decoration:none; }
  .brand-logo{
    height: 100px;
  }
  .brand-logo img{ width:100%; height:100%; object-fit:contain; padding:6px; }
  .brand-name{ display:flex; flex-direction:column; line-height:1.05; }
  .brand-name strong{ font-weight: 950; color: var(--hd-text); }
  .brand-name span{ font-size:.82rem; color: var(--hd-muted); font-weight: 700; }

  .header-search .form-select{
    max-width: 210px;
    border-top-left-radius: 999px;
    border-bottom-left-radius: 999px;
  }
  .header-search .form-control{ border-radius: 0; }
  .header-search .btn{
    border-top-right-radius: 999px;
    border-bottom-right-radius: 999px;
    font-weight: 900;
  }

  .header-nav{
    border-top: 1px solid var(--hd-border);
    background: rgba(0,0,0,.015);
  }
  body.theme-dark .header-nav{ background: rgba(255,255,255,.03); }

  .nav-list{
    display:flex; gap:6px; flex-wrap:wrap;
    padding: 10px 0;
    margin: 0;
    list-style: none;
  }
  .nav-list a{
    display:flex; align-items:center; gap:10px;
    padding: 10px 14px;
    border-radius: 999px;
    text-decoration:none;
    border: 1px solid transparent;
    color: var(--hd-text);
    font-weight: 900;
    transition: background .12s ease, transform .08s ease, border-color .12s ease;
  }
  .nav-list a:hover{
    background: rgba(13,110,253,.08);
    border-color: rgba(13,110,253,.18);
    transform: translateY(-1px);
  }

  .nav-list .dropdown-menu{
    border-radius: 18px;
    border: 1px solid var(--hd-border);
    box-shadow: var(--hd-shadow);
    background: var(--hd-glass);
  }

  .indicator-btn{
    display:flex; align-items:center; gap:10px;
    padding: 8px 12px;
    border-radius: 16px;

    background: var(--hd-glass2);
    text-decoration:none;
    color: var(--hd-text);
    min-height: 46px;
  }
  /* ✅ Panier desktop : un peu plus large + total mis en valeur */
.indicator-btn.indicator-cart{
  padding: 10px 16px;          /* un peu plus large */
  min-width: 245px;            /* élargit le bloc panier */
}

.indicator-btn.indicator-cart #cartTotalMini{
  font-weight: 950 !important; /* bien gras */
  font-size: 1.2rem;           /* plus visible */
  color: var(--hd-text);
}
  .indicator-title{ font-size:1.2rem; font-weight: 900; line-height:1; }
  .indicator-value{ font-size:.78rem; color: var(--hd-muted); font-weight: 800; }
  .indicator-icon{ position: relative; width: 45px; height: 45px; border-radius: 14px; display:grid; place-items:center; }
  body.theme-dark .indicator-icon{ background: rgba(13,110,253,.16); }

  .theme-toggle{
    border:none;
    background: var(--hd-glass2);
    border: 1px solid var(--hd-border);
    border-radius: 999px;
    padding: 7px 10px;
    display:flex; align-items:center; gap:8px;
    color: var(--hd-text);
    font-weight: 900;
  }
  .theme-toggle .dot{
    width: 18px; height: 18px; border-radius: 999px;
    background: rgba(255,193,7,.95);
    box-shadow: 0 0 0 4px rgba(255,193,7,.18);
  }
  body.theme-dark .theme-toggle .dot{
    background: rgba(13,110,253,.95);
    box-shadow: 0 0 0 4px rgba(13,110,253,.18);
  }

  .offcanvas{
    border-left: 1px solid var(--hd-border);
    background: var(--hd-glass);
    color: var(--hd-text);
  }
  .offcanvas .offcanvas-title{ font-weight: 950; }
  .offcanvas a{ color: var(--hd-text); }

  /* FIX: dropdowns topbar qui se font couper par la bande dessous */
  .header-topbar{
    overflow: visible !important;
    position: relative;
    z-index: 1030;
  }
  .header-topbar .dropdown-menu{ z-index: 2000; }

  /* ✅ MOBILE ONLY: logo gauche / actions droite / recherche en dessous (desktop inchangé) */
@media (max-width: 991.98px){
  .header-main-row{
    flex-wrap: wrap !important;
    gap: 10px !important;
  }

  /* 1) Logo bien à gauche (largeur stable) */
  .brand-box{ order: 1; flex: 0 0 auto; }
  .brand-logo{
    height: 50px;
    width: 140px; /* ajuste si tu veux: 120/160 */
  }

  /* 2) Actions bien à droite */
  .mobile-actions{
    order: 2;
    margin-left: auto;
    flex: 0 0 auto;
    display:flex;
    align-items:center;
    gap: 10px;
  }

  /* 3) Recherche FORCÉE en dessous (override flex-grow-1 bootstrap) */
  .header-search{
    order: 3;
    flex: 0 0 100% !important;
    width: 100% !important;
    flex-grow: 0 !important;
    margin-top: 2px;
 
  }

  .header-search .form-control{ border-radius: 999px 0 0 999px; }
  .header-search .btn{ border-radius: 0 999px 999px 0; }

  }
 /* ===== THEME SWITCH : icône DANS le switch ===== */
.theme-switch-wrap{ display:flex; align-items:center; }

.theme-switch{
  width: 58px !important;
  height: 30px !important;
  border-radius: 999px !important;
  cursor: pointer;
  border: 1px solid var(--hd-border) !important;
  position: relative;
  background: rgba(255,193,7,.30) !important; /* light track */
  box-shadow: inset 0 0 0 1px rgba(0,0,0,.04);
  transition: background .22s ease, border-color .22s ease, box-shadow .22s ease;
}

body.theme-dark .theme-switch{
  background: rgba(233,236,239,.75) !important; /* dark track */
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.06);
}

.theme-switch:focus{
  box-shadow: 0 0 0 .2rem rgba(13,110,253,.20) !important;
}

/* ✅ Thumb custom (on cache celui de Bootstrap et on dessine le nôtre) */
.theme-switch::before{
  content:"";
  position:absolute;
  top: 50%;
  left: 3px;
  width: 24px;
  height: 24px;
  transform: translateY(-50%);
  border-radius: 999px;
  background: rgba(255,255,255,.98);
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 10px 20px rgba(0,0,0,.12);
  transition: left .26s ease, background .22s ease, border-color .22s ease;
  z-index: 1;
}

/* ✅ Icône dans le thumb (par défaut = soleil) */
.theme-switch::after{
  content:"\f185"; /* fa-sun */
  font-family: "Font Awesome 6 Free";
  font-weight: 900;
  position:absolute;
  top: 50%;
  left: 3px;
  width: 24px;
  height: 24px;
  transform: translateY(-50%);
  display:grid;
  place-items:center;
  color: rgba(255,140,0,.95);
  transition: left .26s ease, transform .26s ease, opacity .18s ease;
  z-index: 2;
}

/* ✅ Quand checked => mode dark (thumb à droite + lune) */
.theme-switch:checked::before{
  left: calc(100% - 3px - 24px);
  background: rgba(255,255,255,.98);
}
.theme-switch:checked::after{
  left: calc(100% - 3px - 24px);
  content:"\f186"; /* fa-moon */
  color: rgba(55,65,81,.95);
}

/* petite animation "glide" au changement */
.theme-switch:active::before{
  width: 28px;
}
.theme-switch:active::after{
  transform: translateY(-50%) scale(1.05);
}

/* supprime l’espace du label bootstrap */
.theme-switch-label{ margin:0; padding:0; }



/* ===== Cart items (offcanvas) : belle présentation ===== */
.cart-item{
  display:flex;
  gap: 12px;
  align-items:center;
  padding: 10px;
  border-radius: 16px;
  border: 1px solid var(--hd-border);
  background: var(--hd-glass2);
}

.cart-thumb{
  width: 56px;
  height: 56px;
  border-radius: 14px;
  border: 1px solid var(--hd-border);
  background: rgba(0,0,0,.03);
  object-fit: contain;
  padding: 6px;
  flex: 0 0 auto;
}

body.theme-dark .cart-thumb{
  background: rgba(255,255,255,.05);
}

.cart-info{
  min-width: 0;
  flex: 1;
}

.cart-title{
  font-weight: 950;
  font-size: .92rem;
  line-height: 1.12;
  color: var(--hd-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cart-ref{
  margin-top: 4px;
  font-size: .80rem;
  font-weight: 900;
  color: var(--hd-muted);
}

.cart-right{
  display:flex;
  flex-direction: column;
  align-items:flex-end;
  gap: 6px;
  flex: 0 0 auto;
}

.cart-qty{
  border-radius: 999px;
  padding: 6px 10px;
  font-size: .78rem;
  font-weight: 950;
  border: 1px solid var(--hd-border);
  background: rgba(255,255,255,.70);
  color: var(--hd-text);
  white-space: nowrap;
}

body.theme-dark .cart-qty{
  background: rgba(18,18,22,.55);
}

.cart-subtotal{
  font-size: .82rem;
  font-weight: 950;
  color: var(--hd-text);
  white-space: nowrap;
}

/* ✅ Bouton "Nouveaux Deals" : plus large + pas de retour ligne */
.indicator-btn.indicator-deals{
  padding: 10px 16px;     /* un peu plus large */
  min-width: 220px;       /* élargit */
}

.indicator-btn.indicator-deals .indicator-title{
  white-space: nowrap;    /* ✅ empêche le retour à la ligne */
}
/* ✅ Search bar clean : bg gris + loupe dans l’input */
.header-search .search-wrap{
  position: relative;
  width: 100%;
}

.header-search .search-ico{
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: rgba(0,0,0,.45);
  pointer-events: none;
  font-size: 1rem;
}

body.theme-dark .header-search .search-ico{
  color: rgba(255,255,255,.55);
}

.header-search .search-input{
  width: 100%;
  height: 46px;
  padding-left: 44px !important; /* place pour l'icône */
  padding-right: 14px !important;
  border: 1px solid var(--hd-border) !important;
  background: rgba(0,0,0,.06) !important; /* gris clair */
  color: var(--hd-text) !important;
  font-weight: 800;
}

body.theme-dark .header-search .search-input{
  background: rgba(255,255,255,.08) !important;
}

.header-search .search-input::placeholder{
  color: rgba(0,0,0,.45);
  font-weight: 700;
}
body.theme-dark .header-search .search-input::placeholder{
  color: rgba(255,255,255,.55);
}

.header-search .search-input:focus{
  outline: none !important;
  box-shadow: 0 0 0 .2rem rgba(13,110,253,.18) !important;
  background: rgba(0,0,0,.05) !important;
}
body.theme-dark .header-search .search-input:focus{
  background: rgba(255,255,255,.10) !important;
}
/* ✅ Catégories injectées : look clean (comme les autres items) */
.main-menu__item.cat-item .main-menu__link{
  background: transparent;
}

.main-menu__item.cat-item .main-menu__link:hover{
  background: rgb(253, 13, 13);
  color:white;
}

/* Si tu veux limiter la largeur d’un item long */
.main-menu__item.cat-item .main-menu__link span{
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display:inline-block;
}
/* ===== Navbar menu style (capram-like) ===== */
.header__navbar{
  border-top: 1px solid var(--hd-border);
  background: rgba(0,0,0,.015);
  padding: 10px 0;
}
body.theme-dark .header__navbar{ background: rgba(255,255,255,.03); }

.main-menu__list{
  list-style: none;
  display:flex;
  gap: 8px;
  margin: 0;
  padding: 0;
  flex-wrap: wrap;
  align-items:center;
}

.main-menu__item{ position: relative; }

.main-menu__link{
  display:flex;
  align-items:center;
  padding: 5px 5px;
  border-radius: 5px;
  text-decoration:none;
  color: var(--hd-text);
  font-weight: 950;
  border: 1px solid transparent;
  transition: background .12s ease, border-color .12s ease, transform .08s ease;
  white-space: nowrap;
}

.main-menu__link:hover{
  background: rgba(13,110,253,.08);
  border-color: rgba(13,110,253,.18);
  transform: translateY(-1px);
}

.main-menu__link--primary{
  background: rgba(220,53,69,.12);
  border-color: rgba(220,53,69,.22);
  color: rgba(220,53,69,.95);
}
.main-menu__link--primary:hover{
  background: rgba(220,53,69,.18);
  border-color: rgba(220,53,69,.30);
}

/* ===== Submenu ===== */
.main-menu__submenu{
  position:absolute;
  top: calc(100% + 10px);
  left: 0;
  min-width: 320px;
  background: var(--hd-glass);
  border: 1px solid var(--hd-border);
  border-radius: 18px;
  box-shadow: var(--hd-shadow);
  padding: 8px;
  display:none;
  z-index: 2000;
}

.main-menu__item--has-submenu:hover .main-menu__submenu{
  display:block;
}

.menu{
  list-style:none;
  margin:0;
  padding:0;
  display:grid;
  gap: 6px;
}

.menu__link{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 14px;
  text-decoration:none;
  color: var(--hd-text);
  font-weight: 900;
  background: var(--hd-glass2);
  border: 1px solid rgba(0,0,0,.06);
}
body.theme-dark .menu__link{ border-color: rgba(255,255,255,.10); }

.menu__link:hover{
  background: rgba(13,110,253,.08);
  border-color: rgba(13,110,253,.16);
}

.menu-arrow-down{ opacity:.7; }



/* ✅ SVG icons in nav */
.menu-svg{
  height: 27px;
  flex: 0 0 auto;
  display:inline-block;
  color: rgba(0, 0, 0, 0.95); /* rouge comme ton thème */
}
body.theme-dark .menu-svg{ color: rgba(255,193,7,.95); } /* petit contraste en dark */

.menu-svg svg{
  width:100%;
  height:100%;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}
</style>

<header class="site__header">
  <div class="header-wrap">
    <div class="header-topbar">
      <div class="container">
        <div class="topbar-row">
          <div class="topbar-welcome">
            Bienvenue&nbsp;
            <span class="account-name">
              {{ app.user ? (app.user.userIdentifier ?? 'Hopic') : 'Hopic' }}
            </span>
          </div>

          <a class="topbar-phone d-none d-md-flex" href="tel:+212522319354">
            <i class="fa-solid fa-square-phone"></i>
            <span>+212 522 31 93 54</span>
          </a>

          <div class="topbar-spacer"></div>
<div class="theme-switch-wrap" title="Thème">
  <div class="form-check form-switch m-0">
    <input class="form-check-input theme-switch" type="checkbox" id="themeSwitch">
    <label class="form-check-label theme-switch-label" for="themeSwitch" aria-label="Thème"></label>
  </div>
</div>

          <div class="dropdown hd-dropdown">
            <button class="hd-iconbtn position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
              <i class="fa-solid fa-bell"></i>
              <span class="badge text-bg-danger hd-badge" id="notifCount">1</span>
            </button>

            <div class="dropdown-menu dropdown-menu-end p-0">
              <div class="notif-head">
                <h6>Notifications</h6>
                <button type="button" id="markNotifRead">Marquer comme lu</button>
              </div>

              <a href="#" class="notif-item">
                <span class="notif-dot" data-notif-dot></span>
                <div class="notif-content">
                  <p><span class="fw-bold" style="color:#F7943D">Nouveau</span> produit ajouté à la catégorie : <span class="fw-bold" style="color:#F7943D">Lubrifiant</span></p>
                  <span class="notif-time">Aujourd’hui à 17:10</span>
                </div>
              </a>
            </div>
          </div>

          {# ✅ dropdown user #}
          <div class="dropdown hd-dropdown">
            <button class="hd-iconbtn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Compte">
              <i class="fa-solid fa-user"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
              {% if app.user %}
                <li>
                  <span class="dropdown-item-text">
                    Connecté : <strong>{{ app.user.userIdentifier }}</strong>
                  </span>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a class="dropdown-item" href="#">
                    <i class="fa-solid fa-id-card me-2"></i> Mon compte
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="#">
                    <i class="fa-solid fa-user-gear me-2"></i> Profil
                  </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                    <i class="fa-solid fa-right-from-bracket me-2"></i> Déconnexion
                  </a>
                </li>
              {% else %}
                <li>
                  <a class="dropdown-item" href="{{ path('app_login') }}">
                    <i class="fa-solid fa-right-to-bracket me-2"></i> Connexion
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="#">
                    <i class="fa-solid fa-user-plus me-2"></i> Créer un compte
                  </a>
                </li>
              {% endif %}
            </ul>
